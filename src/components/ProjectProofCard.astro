---
interface Props {
  name: string;
  status: string;
  summary: string;
  proof: string;
}

const { name, status, summary, proof } = Astro.props;
---

<article class="evidence-module">
  <div class="module-header">
    <h3 class="project-title">{name}</h3>
    <span class="badge tech-badge">{status}</span>
  </div>
  <div class="module-content">
    <p class="project-desc">{summary}</p>
    <div class="project-proof">
      <span class="eyebrow">Proof Point</span>
      <p>{proof}</p>
    </div>
  </div>
</article>

<style>
  .evidence-module {
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
    border-radius: 0;
    display: grid;
    grid-template-columns: 260px 1fr;
    transition: border-color 0.2s ease;
  }
  .evidence-module:hover {
    border-color: var(--current-muted);
  }
  @media (max-width: 768px) {
    .evidence-module {
      grid-template-columns: 1fr;
    }
  }
  .module-header {
    padding: 2.5rem;
    border-right: 1px solid var(--current-border);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  @media (max-width: 768px) {
    .module-header {
      border-right: none;
      border-bottom: 1px solid var(--current-border);
      padding: 2rem;
    }
  }
  .project-title {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .tech-badge {
    background-color: var(--zone-b-bg);
    border: 1px solid var(--current-border);
    font-size: 0.8rem;
    padding: 0.4rem 0.8rem;
    border-radius: 0;
  }
  .module-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 768px) {
    .module-content {
      padding: 2rem;
    }
  }
  .project-desc {
    color: var(--current-muted);
    font-size: 1.1rem;
    margin-bottom: 3rem;
    line-height: 1.6;
    flex-grow: 1;
  }
  .project-proof {
    padding-top: 2rem;
    border-top: 1px solid var(--current-line);
  }
  .project-proof p {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    color: var(--current-text);
  }
</style>
