---
interface Props {
  name: string;
  status: string;
  summary: string;
  proof: string;
  proofRole?: string;
  href?: string;
  linkLabel?: string;
  evidence?: {
    repo?: string;
    repoLabel?: string;
    website?: string;
    docs?: string;
  };
  compact?: boolean;
  variant?: "standard" | "protocol" | "ledger-row";
}

const {
  name,
  status,
  summary,
  proof,
  proofRole,
  href,
  linkLabel = "Open project record",
  evidence,
  compact = false,
  variant = "standard"
} = Astro.props;
---

<article class:list={[
  "registry-chassis evidence-record",
  compact && "evidence-record--compact",
  variant === "protocol" && "variant-protocol",
  variant === "ledger-row" && "variant-ledger-row"
]}>
  <div class="record-header">
    {variant === "protocol" ? (
      <div class="metadata-grid">
        <div class="registry-annotation">
          <span class="registry-key">PATH_ROLE</span><span class="registry-value">PROTOCOL_PATH</span>
        </div>
        <div class="registry-annotation">
          <span class="registry-key">LAYER</span><span class="registry-value">LIFECYCLE_PROTOCOL</span>
        </div>
        <div class="registry-annotation">
          <span class="registry-key">FUNCTION</span><span class="registry-value">MAKES_AGENTIC_DELIVERY_GOVERNABLE</span>
        </div>
      </div>
    ) : variant === "ledger-row" ? (
      <>
        <div class="registry-annotation">
          <span class="registry-key">PROJECT_ID</span>: <span class="registry-value">{name.toUpperCase()}</span>
        </div>
        {proofRole && (
          <div class="registry-annotation stack-layer-line">
            <span class="registry-key">PATH_ROLE</span>: <span class="registry-value">{proofRole}</span>
          </div>
        )}
        <div class="registry-annotation">
          <span class="registry-key">STATUS</span>: <span class="registry-value">{status.toUpperCase()}</span>
        </div>
        <div class="registry-annotation">
          <span class="registry-key">EVIDENCE_FUNCTION</span>: <span class="registry-value">{summary}</span>
        </div>
      </>
    ) : (
      <>
        <div class="registry-annotation">
          <span class="registry-key">PROJECT_ID</span>: <span class="registry-value">{name.toUpperCase()}</span>
        </div>
        {proofRole && (
          <div class="registry-annotation stack-layer-line">
            <span class="registry-key">PATH_ROLE</span>: <span class="registry-value">{proofRole}</span>
          </div>
        )}
        <div class="registry-annotation">
          <span class="registry-key">STATUS</span>: <span class="registry-value">{status.toUpperCase()}</span>
        </div>
      </>
    )}
  </div>
  
  <div class="record-content">
    <h3 class="record-title">{name}</h3>
    {variant !== "ledger-row" && <p class="record-summary">{summary}</p>}
    
    <div class="proof-block">
      <div class="registry-annotation" style="margin-bottom: 0.75rem;">
        <span class="proof-signal-dot"></span>
        <span class="registry-key">RECORD_CLAIM</span>
      </div>
      <p class="proof-text">{proof}</p>
    </div>

    {href && (
      <a href={href} class="proof-link">{linkLabel}</a>
    )}

    {evidence && (evidence.repo || evidence.website || evidence.docs) && (
      <div class="evidence-surface">
        <div class="registry-annotation" style="margin-bottom: 0.75rem;">
          <span class="registry-key">EVIDENCE_SURFACE</span>
        </div>
        <div class="evidence-links">
          {evidence.repo && (
            <a href={evidence.repo} target="_blank" rel="noopener noreferrer" class="evidence-pill">
              <span class="evidence-pill-key">SOURCE</span>
              <span class="evidence-pill-value">{evidence.repoLabel || "Repository"}</span>
            </a>
          )}
          {evidence.website && (
            <a href={evidence.website} target="_blank" rel="noopener noreferrer" class="evidence-pill">
              <span class="evidence-pill-key">SITE</span>
              <span class="evidence-pill-value">{new URL(evidence.website).host}</span>
            </a>
          )}
          {evidence.docs && (
            <a href={evidence.docs} target="_blank" rel="noopener noreferrer" class="evidence-pill">
              <span class="evidence-pill-key">DOCS</span>
              <span class="evidence-pill-value">{new URL(evidence.docs).host}</span>
            </a>
          )}
        </div>
      </div>
    )}
  </div>
</article>

<style>
  .evidence-record {
    border-radius: var(--radius-module);
    padding: var(--registry-panel-padding);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
    min-width: 0;
  }
  .record-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--current-line);
  }
  .record-content {
    min-width: 0;
  }
  .record-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0 0 0.85rem 0;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .stack-layer-line {
    margin-bottom: 0.7rem;
  }
  .record-summary {
    font-size: 1rem;
    color: var(--current-muted);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    max-width: 60ch;
  }
  .proof-block {
    background-color: rgba(34, 211, 238, 0.03);
    border: 1px solid rgba(34, 211, 238, 0.1);
    padding: var(--registry-compact-padding);
    border-radius: 4px;
  }
  .proof-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--current-text);
    margin: 0;
    line-height: 1.5;
  }
  .proof-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .proof-link:hover {
    color: var(--current-text);
  }
  .evidence-record--compact {
    padding: var(--registry-compact-padding);
    gap: 1rem;
  }
  .evidence-record--compact .record-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
    padding-bottom: 0.85rem;
  }
  .evidence-record--compact .record-header .registry-annotation {
    min-width: 0;
    width: 100%;
    gap: 0.35rem;
    font-size: 0.52rem;
    letter-spacing: 0.045em;
    white-space: nowrap;
  }
  .evidence-record--compact .record-title {
    font-size: 1.08rem;
    line-height: 1.15;
    margin-bottom: 0.55rem;
    white-space: nowrap;
  }
  .evidence-record--compact .stack-layer-line {
    margin-bottom: 0.5rem;
    font-size: 0.52rem;
    white-space: nowrap;
  }
  .evidence-record--compact .record-summary {
    min-height: 3.9rem;
    font-size: 0.78rem;
    line-height: 1.45;
    margin-bottom: 1rem;
  }
  .evidence-record--compact .proof-block {
    padding: 0.85rem;
  }
  .evidence-record--compact .proof-block .registry-annotation {
    margin-bottom: 0.55rem !important;
    font-size: 0.52rem;
    white-space: nowrap;
  }
  .evidence-record--compact .proof-text {
    font-size: 0.74rem;
    line-height: 1.45;
  }
  .evidence-record--compact .proof-link {
    font-size: 0.58rem;
    letter-spacing: 0.06em;
  }
  .evidence-record--compact .evidence-surface {
    margin-top: var(--space-2);
    padding: 0.85rem;
  }
  .evidence-record--compact .evidence-surface .registry-annotation {
    margin-bottom: 0.55rem !important;
    font-size: 0.52rem;
    white-space: nowrap;
  }
  .evidence-record--compact .evidence-links {
    gap: 0.45rem;
  }
  .evidence-record--compact .evidence-pill {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    justify-content: flex-start;
    padding: 0.38rem 0.55rem;
    gap: 0.32rem;
    font-size: 0.52rem;
    letter-spacing: 0.03em;
  }
  .evidence-record--compact .evidence-pill-key,
  .evidence-record--compact .evidence-pill-value {
    white-space: nowrap;
  }
  .evidence-record--compact .evidence-pill-value {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 768px) {
    .evidence-record {
      padding: var(--registry-card-padding);
      gap: 1.35rem;
    }

    .record-header {
      flex-wrap: wrap;
      gap: 0.65rem 1rem;
    }

    .record-title {
      font-size: 1.28rem;
      margin-bottom: 0.7rem;
    }

    .record-summary {
      font-size: 0.95rem;
      margin-bottom: 1.1rem;
    }

    .proof-block {
      padding: var(--registry-compact-padding);
    }

  .proof-text {
    font-size: 0.88rem;
  }
  }

  .evidence-surface {
    margin-top: 1.25rem;
    padding: var(--registry-compact-padding);
    border-left: 3px solid var(--accent-signal);
    background: rgba(59, 130, 246, 0.02);
    border-radius: 0 4px 4px 0;
  }
  .evidence-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .evidence-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--current-muted);
    border: 1px solid var(--current-border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
    min-width: 0;
  }
  .evidence-pill:hover {
    border-color: var(--accent-signal);
    color: var(--accent-signal);
  }
  .evidence-pill-key {
    font-weight: 700;
    color: var(--accent-signal);
    white-space: nowrap;
  }
  .evidence-pill-value {
    min-width: 0;
  }

  /* Variant: Protocol Monolith */
  .variant-protocol {
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
    border-top: 4px solid var(--accent-signal);
    padding: var(--registry-panel-padding-lg);
  }
  .variant-protocol .record-header {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--current-line);
    margin-bottom: 2rem;
  }
  .variant-protocol .record-title {
    font-size: clamp(2.8rem, 5vw, 4rem);
    letter-spacing: -0.03em;
    color: var(--current-text);
    margin-bottom: 1.5rem;
  }
  .variant-protocol .record-summary {
    font-size: 1.25rem;
    max-width: var(--lead-measure);
    color: var(--current-text);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }
  .variant-protocol .proof-block {
    background: transparent;
    border: none;
    border-top: 1px solid var(--current-line);
    border-radius: 0;
    padding: 2rem 0 0 0;
    margin-top: 2rem;
  }

  .metadata-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1.5rem;
    row-gap: 0.8rem;
    align-items: baseline;
  }
  .metadata-grid .registry-annotation {
    display: contents; /* Allows key and value to act as direct grid children */
  }

  /* Variant: Ledger Row */
  .variant-ledger-row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    padding: var(--registry-panel-padding);
    border: none;
    border-bottom: 1px solid var(--current-line);
    background-color: transparent;
    border-radius: 0;
    transition: background-color 0.25s ease;
  }
  .variant-ledger-row:last-child {
    border-bottom: none;
  }
  .variant-ledger-row:hover {
    background-color: rgba(59, 130, 246, 0.03);
  }
  .variant-ledger-row .record-header {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    width: auto;
    border: none;
    padding: 0;
  }
  .variant-ledger-row .record-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .variant-ledger-row .record-title {
    font-size: 1.35rem;
    margin-bottom: 1.5rem;
  }
  .variant-ledger-row .proof-block {
    background: transparent;
    border: none;
    border-left: 2px solid var(--accent-proof);
    border-radius: 0;
    padding: 0 0 0 1.25rem;
    margin-bottom: 1rem;
  }
  .variant-ledger-row .evidence-surface {
    margin-top: 0;
    padding: 1rem 0 0 0;
    border-left: none;
    background: transparent;
    border-top: 1px dashed var(--current-line);
    border-radius: 0;
  }

  @media (max-width: 1024px) {
    .variant-ledger-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .variant-ledger-row .record-header {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
      border-bottom: 1px solid var(--current-line);
      padding-bottom: 1.25rem;
    }
  }

  @media (max-width: 768px) {
    .metadata-grid {
      grid-template-columns: 1fr;
      row-gap: 0.4rem;
    }
    .metadata-grid .registry-annotation {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
      margin-bottom: 0.5rem;
    }
    .variant-ledger-row .record-header {
      flex-direction: column;
      gap: 0.8rem;
    }
    .variant-protocol .record-header {
      flex-direction: column;
      gap: 0.8rem;
    }
  }
</style>
