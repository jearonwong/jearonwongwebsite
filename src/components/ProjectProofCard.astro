---
interface Props {
  name: string;
  status: string;
  summary: string;
  proof: string;
}

const { name, status, summary, proof } = Astro.props;
---

<article class="structural-panel glass-panel-light">
  <div class="panel-header">
    <h3 class="project-title">{name}</h3>
    <span class="badge tech-badge">{status}</span>
  </div>
  <p class="project-desc">{summary}</p>
  <div class="project-proof">
    <span class="proof-label">Proof Point</span>
    <p class="proof-text">{proof}</p>
  </div>
</article>

<style>
  .structural-panel {
    background-color: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: var(--radius-genesis);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .structural-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    border-color: var(--accent-kinetic);
  }
  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  .project-title {
    flex-direction: column;
  }
  @media (max-width: 768px) {
    .module-content {
      padding: 2rem;
    }
  }
  .project-desc {
    color: var(--current-muted);
    font-size: 1.1rem;
    margin-bottom: 3rem;
    line-height: 1.6;
    flex-grow: 1;
  }
  .project-proof {
    padding-top: 2rem;
    border-top: 1px solid var(--current-line);
  }
  .project-proof p {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    color: var(--current-text);
  }
</style>
