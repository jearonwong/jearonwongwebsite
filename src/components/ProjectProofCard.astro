---
interface Props {
  name: string;
  status: string;
  summary: string;
  proof: string;
  proofRole?: string;
  href?: string;
  linkLabel?: string;
  evidence?: {
    repo?: string;
    repoLabel?: string;
    website?: string;
    docs?: string;
  };
  compact?: boolean;
}

const {
  name,
  status,
  summary,
  proof,
  proofRole,
  href,
  linkLabel = "Open proof record",
  evidence,
  compact = false
} = Astro.props;
---

<article class:list={["registry-chassis evidence-record", compact && "evidence-record--compact"]}>
  <div class="record-header">
    <div class="registry-annotation">
      <span class="registry-key">PROJECT_ID</span>: <span class="registry-value">{name.toUpperCase()}</span>
    </div>
    <div class="registry-annotation">
      <span class="registry-key">STATUS</span>: <span class="registry-value">{status.toUpperCase()}</span>
    </div>
  </div>
  
  <div class="record-content">
    {proofRole && (
      <div class="registry-annotation stack-layer-line">
        <span class="registry-key">PROOF_ROLE</span>: <span class="registry-value">{proofRole}</span>
      </div>
    )}
    <h3 class="record-title">{name}</h3>
    <p class="record-summary">{summary}</p>
    
    <div class="proof-block">
      <div class="registry-annotation" style="margin-bottom: 0.75rem;">
        <span class="proof-signal-dot"></span>
        <span class="registry-key">RECORD_PROOF</span>
      </div>
      <p class="proof-text">{proof}</p>
    </div>

    {href && (
      <a href={href} class="proof-link">{linkLabel}</a>
    )}

    {evidence && (evidence.repo || evidence.website || evidence.docs) && (
      <div class="evidence-surface">
        <div class="registry-annotation" style="margin-bottom: 0.75rem;">
          <span class="registry-key">EVIDENCE_SURFACE</span>
        </div>
        <div class="evidence-links">
          {evidence.repo && (
            <a href={evidence.repo} target="_blank" rel="noopener noreferrer" class="evidence-pill">
              <span class="evidence-pill-key">SOURCE</span>
              <span class="evidence-pill-value">{evidence.repoLabel || "Repository"}</span>
            </a>
          )}
          {evidence.website && (
            <a href={evidence.website} target="_blank" rel="noopener noreferrer" class="evidence-pill">
              <span class="evidence-pill-key">SITE</span>
              <span class="evidence-pill-value">{new URL(evidence.website).host}</span>
            </a>
          )}
          {evidence.docs && (
            <a href={evidence.docs} target="_blank" rel="noopener noreferrer" class="evidence-pill">
              <span class="evidence-pill-key">DOCS</span>
              <span class="evidence-pill-value">{new URL(evidence.docs).host}</span>
            </a>
          )}
        </div>
      </div>
    )}
  </div>
</article>

<style>
  .evidence-record {
    border-radius: var(--radius-module);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
    min-width: 0;
  }
  .record-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--current-line);
  }
  .record-content {
    min-width: 0;
  }
  .record-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0 0 0.85rem 0;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .stack-layer-line {
    margin-bottom: 0.7rem;
  }
  .record-summary {
    font-size: 1rem;
    color: var(--current-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 60ch;
  }
  .proof-block {
    background-color: rgba(34, 211, 238, 0.03);
    border: 1px solid rgba(34, 211, 238, 0.1);
    padding: 1.25rem;
    border-radius: 4px;
  }
  .proof-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--current-text);
    margin: 0;
    line-height: 1.5;
  }
  .proof-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .proof-link:hover {
    color: var(--current-text);
  }
  .evidence-record--compact {
    padding: 1.25rem;
    gap: 1.05rem;
  }
  .evidence-record--compact .record-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
    padding-bottom: 0.85rem;
  }
  .evidence-record--compact .record-header .registry-annotation {
    min-width: 0;
    width: 100%;
    gap: 0.35rem;
    font-size: 0.52rem;
    letter-spacing: 0.045em;
    white-space: nowrap;
  }
  .evidence-record--compact .record-title {
    font-size: 1.08rem;
    line-height: 1.15;
    margin-bottom: 0.55rem;
    white-space: nowrap;
  }
  .evidence-record--compact .stack-layer-line {
    margin-bottom: 0.5rem;
    font-size: 0.52rem;
    white-space: nowrap;
  }
  .evidence-record--compact .record-summary {
    min-height: 3.9rem;
    font-size: 0.78rem;
    line-height: 1.45;
    margin-bottom: 1rem;
  }
  .evidence-record--compact .proof-block {
    padding: 0.8rem;
  }
  .evidence-record--compact .proof-block .registry-annotation {
    margin-bottom: 0.55rem !important;
    font-size: 0.52rem;
    white-space: nowrap;
  }
  .evidence-record--compact .proof-text {
    font-size: 0.74rem;
    line-height: 1.45;
  }
  .evidence-record--compact .proof-link {
    font-size: 0.58rem;
    letter-spacing: 0.06em;
  }
  .evidence-record--compact .evidence-surface {
    margin-top: 1rem;
    padding: 0.8rem;
  }
  .evidence-record--compact .evidence-surface .registry-annotation {
    margin-bottom: 0.55rem !important;
    font-size: 0.52rem;
    white-space: nowrap;
  }
  .evidence-record--compact .evidence-links {
    gap: 0.45rem;
  }
  .evidence-record--compact .evidence-pill {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    justify-content: flex-start;
    padding: 0.38rem 0.55rem;
    gap: 0.32rem;
    font-size: 0.52rem;
    letter-spacing: 0.03em;
  }
  .evidence-record--compact .evidence-pill-key,
  .evidence-record--compact .evidence-pill-value {
    white-space: nowrap;
  }
  .evidence-record--compact .evidence-pill-value {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 768px) {
    .evidence-record {
      padding: 1.75rem;
      gap: 1.35rem;
    }

    .record-header {
      flex-wrap: wrap;
      gap: 0.65rem 1rem;
    }

    .record-title {
      font-size: 1.28rem;
      margin-bottom: 0.7rem;
    }

    .record-summary {
      font-size: 0.95rem;
      margin-bottom: 1.1rem;
    }

    .proof-block {
      padding: 1rem;
    }

  .proof-text {
    font-size: 0.88rem;
  }
  }

  .evidence-surface {
    margin-top: 1.25rem;
    padding: 1.25rem;
    border-left: 3px solid var(--accent-signal);
    background: rgba(59, 130, 246, 0.02);
    border-radius: 0 4px 4px 0;
  }
  .evidence-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .evidence-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--current-muted);
    border: 1px solid var(--current-border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
    min-width: 0;
  }
  .evidence-pill:hover {
    border-color: var(--accent-signal);
    color: var(--accent-signal);
  }
  .evidence-pill-key {
    font-weight: 700;
    color: var(--accent-signal);
    white-space: nowrap;
  }
  .evidence-pill-value {
    min-width: 0;
  }
</style>
