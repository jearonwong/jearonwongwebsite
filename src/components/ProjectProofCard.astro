---
interface Props {
  name: string;
  status: string;
  summary: string;
  proof: string;
}

const { name, status, summary, proof } = Astro.props;
---

<article class="registry-chassis evidence-record">
  <div class="record-header">
    <div class="registry-annotation">
      <span class="registry-key">PROJECT_ID</span>: <span class="registry-value">{name.toUpperCase()}</span>
    </div>
    <div class="registry-annotation">
      <span class="registry-key">STATUS</span>: <span class="registry-value">{status.toUpperCase()}</span>
    </div>
  </div>
  
  <div class="record-content">
    <h3 class="record-title">{name}</h3>
    <p class="record-summary">{summary}</p>
    
    <div class="proof-block">
      <div class="registry-annotation" style="margin-bottom: 0.75rem;">
        <span class="proof-signal-dot"></span>
        <span class="registry-key">RECORD_PROOF</span>
      </div>
      <p class="proof-text">{proof}</p>
    </div>
  </div>
</article>

<style>
  .evidence-record {
    border-radius: var(--radius-module);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
  }
  .record-header {
    display: flex;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--current-line);
  }
  .record-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0 0 0.85rem 0;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .record-summary {
    font-size: 1rem;
    color: var(--current-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 60ch;
  }
  .proof-block {
    background-color: rgba(34, 211, 238, 0.03);
    border: 1px solid rgba(34, 211, 238, 0.1);
    padding: 1.25rem;
    border-radius: 4px;
  }
  .proof-text {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--current-text);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .evidence-record {
      padding: 1.75rem;
      gap: 1.35rem;
    }

    .record-header {
      flex-wrap: wrap;
      gap: 0.65rem 1rem;
    }

    .record-title {
      font-size: 1.28rem;
      margin-bottom: 0.7rem;
    }

    .record-summary {
      font-size: 0.95rem;
      margin-bottom: 1.1rem;
    }

    .proof-block {
      padding: 1rem;
    }

    .proof-text {
      font-size: 0.88rem;
    }
  }
</style>
