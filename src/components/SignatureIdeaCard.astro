---
interface Props {
  name: string;
  description: string;
  prompt: string;
}

const { name, description, prompt } = Astro.props;
---

<article class="structural-panel">
  <div class="panel-header">
    <h3 class="idea-title">{name}</h3>
  </div>
  <div class="panel-body">
    <p class="idea-desc">{description}</p>
    <div class="idea-prompt">
      <span class="eyebrow prompt-label">Key Question</span>
      <p class="prompt-text">{prompt}</p>
    </div>
  </div>
</article>

<style>
  .structural-panel {
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
    border-radius: 0;
    padding: 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: -1px; /* collapse borders */
    transition: background-color 0.2s ease;
  }
  .structural-panel:last-child {
    margin-bottom: 0;
  }
  .structural-panel:hover {
    background-color: var(--zone-b-bg);
  }
  .panel-header {
    margin-bottom: 0;
  }
  .idea-title {
    font-size: 1.25rem;
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .panel-body {
    display: flex;
    flex-direction: column;
  }
  .idea-desc {
    color: var(--current-muted);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .idea-prompt {
    padding-top: 1.5rem;
    border-top: 1px solid var(--current-line);
  }
  .prompt-label {
    margin-bottom: 0.5rem;
    display: block;
    color: var(--current-muted);
  }
  .prompt-text {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--current-text);
  }
</style>
