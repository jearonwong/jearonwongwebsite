---
interface Props {
  name: string;
  description: string;
  prompt: string;
}

const { name, description, prompt } = Astro.props;
---

<article class="structural-panel">
  <div class="panel-header">
    <h3 class="idea-title">{name}</h3>
  </div>
  <p class="idea-desc">{description}</p>
  <div class="idea-prompt">
    <span class="eyebrow prompt-label">Key Question</span>
    <p class="prompt-text">{prompt}</p>
  </div>
</article>

<style>
  .structural-panel {
    background-color: transparent;
    border: 1px solid var(--current-border);
    border-radius: var(--radius-sm); /* Sharper border, removing cozy publication feel */
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
    margin-bottom: -1px;
  }
  .structural-panel:hover {
    border-color: var(--current-muted);
  }
  .panel-header {
    margin-bottom: 1rem;
  }
  .idea-title {
    font-size: 1.35rem;
    margin: 0;
    font-weight: 700;
  }
  .idea-desc {
    color: var(--current-muted);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    flex-grow: 1;
  }
  .idea-prompt {
    padding-top: 1.25rem;
    border-top: 1px solid var(--current-line);
  }
  .prompt-label {
    margin-bottom: 0.25rem;
    display: block;
    color: var(--current-muted);
  }
  .prompt-text {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--current-text);
  }
</style>
