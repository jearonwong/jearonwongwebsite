---
interface Props {
  name: string;
  description: string;
  prompt: string;
}

const { name, description, prompt } = Astro.props;
---

<article class="structural-panel glass-panel-light">
  <div class="panel-header">
    <h3 class="idea-title">{name}</h3>
  </div>
  <div class="panel-body">
    <p class="idea-desc">{description}</p>
    <div class="idea-prompt">
      <span class="prompt-label">Key Question</span>
      <p class="prompt-text">{prompt}</p>
    </div>
  </div>
</article>

<style>
  .structural-panel {
    background-color: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: var(--radius-genesis);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .structural-panel:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    border-color: var(--accent-kinetic);
  }
  .idea-title {
    font-size: 1.5rem;
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #0f172a;
  }
  .idea-desc {
    color: #475569;
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 65ch;
  }
  .idea-prompt {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(15, 23, 42, 0.05);
  }
  .prompt-label {
    margin-bottom: 0.75rem;
    display: block;
    color: var(--accent-electric);
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .prompt-text {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    color: #0f172a;
  }
</style>
