---
interface Props {
  name: string;
  description: string;
  prompt: string;
  essayPath?: string;
  essayLabel?: string;
  proofPath?: string;
  proofLabel?: string;
}

const { name, description, prompt, essayPath, essayLabel, proofPath, proofLabel } = Astro.props;
---

<article class="registry-chassis system-pillar">
  <div class="pillar-header">
    <div class="registry-annotation">
      <span class="registry-key">PILLAR_ID</span>: <span class="registry-value">{name.toUpperCase().replace(/\s/g, '_')}</span>
    </div>
  </div>
  
  <div class="pillar-content">
    <div class="registry-annotation" style="margin-bottom: 0.5rem;">
      <span class="registry-key">PILLAR_NAME</span>
    </div>
    <h3 class="pillar-title">{name}</h3>
    <p class="pillar-desc">{description}</p>
    
    <div class="focus-block">
      <div class="registry-annotation" style="margin-bottom: 0.75rem;">
        <span class="registry-key">SPECIFICATION_FOCUS</span>
      </div>
      <p class="focus-text">{prompt}</p>
    </div>

    <div class="idea-links">
      {essayPath && essayLabel && (
        <a href={essayPath} class="idea-link">{essayLabel}</a>
      )}
      {proofPath && proofLabel && (
        <a href={proofPath} class="idea-link">{proofLabel}</a>
      )}
    </div>
  </div>
</article>

<style>
  .system-pillar {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: var(--current-surface);
    border: 1px solid var(--current-border);
  }
  .pillar-header {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--current-line);
  }
  .pillar-title {
    font-size: 1.5rem;
    font-weight: 850;
    margin: 0 0 1rem 0;
    letter-spacing: -0.03em;
    color: var(--current-text);
  }
  .pillar-desc {
    font-size: 1rem;
    color: var(--current-muted);
    line-height: 1.55;
    margin-bottom: 1.5rem;
  }
  .focus-block {
    padding: 1.25rem;
    border: 1px solid var(--border-registry);
    background-color: rgba(255, 255, 255, 0.02);
  }
  .focus-text {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.5;
    margin: 0;
    color: var(--current-text);
    opacity: 0.8;
  }

  .idea-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
    margin-top: 1rem;
  }

  .idea-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }

  .idea-link:hover {
    color: var(--current-text);
  }

  @media (max-width: 768px) {
    .system-pillar {
      padding: 1.75rem;
      gap: 1.1rem;
    }

    .pillar-title {
      font-size: 1.32rem;
      margin-bottom: 0.8rem;
    }

    .pillar-desc {
      font-size: 0.96rem;
      margin-bottom: 1.2rem;
    }

    .focus-block {
      padding: 1rem;
    }

    .focus-text {
      font-size: 0.86rem;
    }

    .idea-link {
      font-size: 0.7rem;
    }
  }
</style>
