---
import SiteHeader from "./SiteHeader.astro";

const title = Astro.props.title;
const subtitle = Astro.props.subtitle;
const objectType = Astro.props.objectType;
const objectValue = Astro.props.objectValue;
const lead = Astro.props.lead;
const zone = Astro.props.zone ?? "zone-a";
const className = Astro.props.class ?? "";
---

<div class:list={[zone, "registry-grid", "registry-page-hero", className]}>
  <SiteHeader />
  <div class="shell registry-page-hero__shell">
    {objectType && objectValue && (
      <div class="registry-annotation registry-page-hero__annotation">
        <span class="registry-key">{objectType}</span>: <span class="registry-value">{objectValue}</span>
      </div>
    )}
    <h1 class="registry-page-hero__title">{title}</h1>
    {subtitle && <p class="registry-page-hero__subtitle">{subtitle}</p>}
    {lead && <p class="lead registry-page-hero__lead">{lead}</p>}
    <slot />
  </div>
</div>

<style>
  .registry-page-hero {
    padding-top: 9.5rem;
    padding-bottom: 5.5rem;
    border-bottom: 1px solid var(--border-registry);
  }

  .registry-page-hero__annotation {
    margin-bottom: 1rem;
  }

  .registry-page-hero__title {
    font-size: clamp(2.3rem, 6vw, 4.1rem);
    font-weight: 850;
    letter-spacing: -0.045em;
    line-height: 0.96;
    margin-bottom: 0.9rem;
    max-width: 13ch;
  }

  .registry-page-hero__subtitle {
    margin: 0 0 1.1rem;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.6vw, 1.55rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    color: var(--current-text);
  }

  .registry-page-hero__lead {
    max-width: 54ch;
    font-size: 1.08rem;
    color: var(--text-registry-muted);
    border-left: 2px solid var(--border-registry);
    padding-left: 1.4rem;
    line-height: 1.65;
  }
</style>
