---
import SiteHeader from "./SiteHeader.astro";

interface Props {
  title: string;
  titleLines?: string[];
  subtitle?: string;
  objectType?: string;
  objectValue?: string;
  lead?: string;
  leadLines?: string[];
  zone?: string;
  class?: string;
}

const {
  title,
  titleLines,
  subtitle,
  objectType,
  objectValue,
  lead,
  leadLines,
  zone = "zone-a",
  class: className = ""
} = Astro.props;

const displayTitleLines = titleLines?.length ? titleLines : null;
const displayLeadLines = leadLines?.length ? leadLines : null;
---

<div class:list={[zone, "registry-grid", "registry-page-hero", className]}>
  <SiteHeader />
  <div class="shell registry-page-hero__shell">
    {objectType && objectValue && (
      <div class="registry-annotation registry-page-hero__annotation">
        <span class="registry-key">{objectType}</span>: <span class="registry-value">{objectValue}</span>
      </div>
    )}
    <h1 class:list={["registry-page-hero__title", displayTitleLines && "has-title-lines"]}>
      {displayTitleLines ? (
        displayTitleLines.map((line) => <span class="registry-page-hero__title-line">{line}</span>)
      ) : (
        title
      )}
    </h1>
    {subtitle && <p class="registry-page-hero__subtitle">{subtitle}</p>}
    {(lead || displayLeadLines) && (
      <p class:list={["lead", "registry-page-hero__lead", displayLeadLines && "has-lead-lines"]}>
        {displayLeadLines ? (
          displayLeadLines.map((line) => <span class="registry-page-hero__lead-line">{line}</span>)
        ) : (
          lead
        )}
      </p>
    )}
    <slot />
  </div>
</div>

<style>
  .registry-page-hero {
    padding-top: clamp(7rem, 10vw, 8.25rem);
    padding-bottom: clamp(4.4rem, 7vw, 5.25rem);
    border-bottom: 1px solid var(--border-registry);
  }

  .registry-page-hero__annotation {
    margin-bottom: 1.35rem;
  }

  .registry-page-hero__title {
    font-size: clamp(2.35rem, 4.15vw, 3.7rem);
    font-weight: 760;
    letter-spacing: -0.018em;
    line-height: 1.08;
    margin: 0 0 1.45rem;
    max-width: min(100%, 17em);
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .registry-page-hero__title-line {
    display: block;
  }

  .registry-page-hero__subtitle {
    margin: 0 0 0.9rem;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.2vw, 1.3rem);
    font-weight: 640;
    letter-spacing: -0.03em;
    color: var(--current-text);
  }

  .registry-page-hero__lead {
    width: min(100%, var(--lead-measure));
    max-width: none;
    font-size: clamp(1.05rem, 1.2vw, 1.18rem);
    color: rgba(226, 232, 240, 0.68);
    border-left: 2px solid rgba(59, 130, 246, 0.32);
    padding-left: var(--registry-compact-padding);
    line-height: 1.62;
  }

  .registry-page-hero__lead-line {
    display: block;
  }

  @media (max-width: 768px) {
    .registry-page-hero {
      padding-top: 6.75rem;
      padding-bottom: 3.5rem;
    }

    .registry-page-hero__annotation {
      margin-bottom: 0.8rem;
    }

    .registry-page-hero__title {
      font-size: clamp(1.85rem, 7.4vw, 2.35rem);
      line-height: 1.1;
      margin-bottom: 1.15rem;
      max-width: 100%;
    }

    .registry-page-hero__subtitle {
      margin-bottom: 0.75rem;
      font-size: clamp(0.95rem, 4vw, 1.12rem);
    }

    .registry-page-hero__lead {
      font-size: 1rem;
      line-height: 1.6;
      padding-left: var(--space-2);
      width: 100%;
    }
  }
</style>
