---
// Portrait Anchor Component
// Implements the Architectural Anchor identity requirement.
---

<div class="portrait-anchor">
  <div class="portrait-panel">
    <div class="bg-grid-overlay"></div>
    <div class="monogram-lockup">
      <span class="monogram">JW</span>
      <span class="monogram-subtitle">PROTOCOL ARCHITECT</span>
    </div>
    <div class="portrait-footer">
      <span class="architect-plaque">Portrait Pending // V.01</span>
    </div>
  </div>
</div>

<style>
  .portrait-anchor {
    display: flex;
    justify-content: flex-end;
    align-items: center; /* Center the panel vertically if the left side is taller */
    width: 100%;
    height: 100%;
  }
  .portrait-panel {
    position: relative;
    width: 100%;
    max-width: 440px;
    aspect-ratio: 1 / 1; /* Square ratio */
    background-color: var(--zone-a-surface);
    border: 1px solid var(--zone-a-border);
    border-radius: 0; /* Harder architectural sharp corners */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .bg-grid-overlay {
    opacity: 0.25; /* Quieter internal noise */
  }
  .monogram-lockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 1;
    user-select: none;
    opacity: 0.9;
  }
  .monogram {
    font-family: var(--font-display);
    font-size: clamp(6rem, 10vw, 10rem);
    font-weight: 800;
    color: var(--zone-a-text);
    letter-spacing: -0.06em;
    line-height: 1;
  }
  .monogram-subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--zone-a-muted);
    letter-spacing: 0.25em;
    margin-top: 0.5rem;
  }
  .portrait-footer {
    position: absolute;
    bottom: 0;
    right: 0;
    z-index: 2;
  }
  .architect-plaque {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background-color: var(--zone-a-bg);
    color: var(--zone-a-text);
    border-top: 1px solid var(--zone-a-border);
    border-left: 1px solid var(--zone-a-border);
  }
</style>
