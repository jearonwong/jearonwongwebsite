---
// Portrait Anchor Component
import { siteConfig } from "../data/site";

const avatarWebp = "/images/jearon-wong-avatar.webp";
const avatarJpg = "/images/jearon-wong-avatar.jpg";
const avatarAlt = `${siteConfig.author.name} portrait`;
---

<div class="portrait-anchor">
  <div class="portrait-panel registry-chassis">
    <picture class="portrait-picture">
      <source srcset={avatarWebp} type="image/webp" />
      <img
        src={avatarJpg}
        alt={avatarAlt}
        class="portrait-image"
        width="1200"
        height="1200"
        loading="eager"
        decoding="async"
      />
    </picture>
    <div class="portrait-shade"></div>
    <div class="registry-grid portrait-grid"></div>
  </div>
</div>

<style>
  .portrait-anchor {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    width: 100%;
    height: 100%;
  }
  .portrait-panel {
    position: relative;
    width: 100%;
    max-width: 440px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background:
      linear-gradient(145deg, rgba(59, 130, 246, 0.1), rgba(17, 17, 17, 0.18) 46%, rgba(255, 255, 255, 0)),
      var(--current-surface);
    border: 1px solid rgba(255, 255, 255, 0.11);
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.42),
      -24px 0 80px rgba(59, 130, 246, 0.07),
      inset 0 0 0 1px rgba(255, 255, 255, 0.026);
  }
  .portrait-picture,
  .portrait-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .portrait-image {
    object-fit: cover;
    object-position: 50% 39%;
  }
  .portrait-shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(17, 17, 17, 0.05) 0%, rgba(17, 17, 17, 0) 45%, rgba(17, 17, 17, 0.34) 100%),
      linear-gradient(90deg, rgba(17, 17, 17, 0.2), rgba(17, 17, 17, 0) 44%, rgba(17, 17, 17, 0.22));
    pointer-events: none;
  }
  .portrait-grid {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    pointer-events: none;
  }
  @media (max-width: 1024px) {
    .portrait-anchor {
      justify-content: flex-start;
    }

    .portrait-panel {
      max-width: 380px;
      aspect-ratio: 4 / 5;
    }
  }
  @media (max-width: 640px) {
    .portrait-panel {
      max-width: 340px;
      aspect-ratio: 4 / 5;
    }

    .portrait-image {
      object-position: 50% 34%;
    }
  }
</style>
