---
import { primaryNav } from "../data/site";
---

<header class="site-monitor-container">
  <div class="shell monitor-shell">
    <div class="logo">
      <a href="/" class="logo-link">
        <div class="brand-lockup">
          <span class="brand-name">Jearon Wang</span>
          <span class="brand-role">Protocol Architect for the Agent Era</span>
        </div>
      </a>
    </div>
    
    <nav class="nav-desktop">
      <ul class="nav-list">
        {primaryNav.map(item => (
          <li class="nav-item">
            <a href={item.href} class="nav-link registry-annotation">
              <span class="registry-value">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <a href="/contact/" class="nav-cta registry-annotation">
        <span class="registry-value">Contact</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-monitor-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding-top: 1rem;
  }
  .monitor-shell {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 2rem;
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: blur(12px);
    border: none;
    border-bottom: 1px solid var(--border-registry);
  }

  .logo-link {
    text-decoration: none;
  }

  .brand-lockup {
    display: grid;
    gap: 0.1rem;
  }

  .brand-name {
    color: var(--text-registry-primary);
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .brand-role {
    color: var(--text-registry-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  
  .nav-list {
    display: flex;
    list-style: none;
    gap: 1.6rem;
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    transition: opacity 0.2s ease;
    text-decoration: none;
  }
  
  .nav-link:hover {
    opacity: 0.7;
  }

  .nav-cta {
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border-registry);
    border-radius: var(--radius-module);
    transition: all 0.2s ease;
  }
  .nav-cta:hover {
    border-color: var(--accent-signal);
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
  }
</style>
