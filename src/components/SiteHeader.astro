---
import { primaryNav, secondaryNav } from "../data/site";

const currentPath =
  Astro.url.pathname.length > 1 && Astro.url.pathname.endsWith("/")
    ? Astro.url.pathname.slice(0, -1)
    : Astro.url.pathname;
const drawerSecondaryNav = secondaryNav.filter(
  (item) => !primaryNav.some((primaryItem) => primaryItem.href === item.href)
);
---

<header class="site-monitor-container">
  <div class="shell monitor-shell">
    <div class="logo">
      <a href="/" class="logo-link">
        <div class="brand-lockup">
          <span class="brand-name">Jearon Wong</span>
          <span class="brand-role">Protocol Architect for the Agent Era</span>
        </div>
      </a>
    </div>
    
    <nav class="nav-desktop">
      <ul class="nav-list">
        {primaryNav.map(item => (
          <li class="nav-item">
            <a
              href={item.href}
              class:list={["nav-link", currentPath === item.href.slice(0, -1) && "is-active"]}
            >
              <span class="nav-label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Mobile hamburger toggle -->
    <input type="checkbox" id="mobile-drawer-toggle" class="drawer-checkbox" aria-hidden="true" />
    <label for="mobile-drawer-toggle" class="hamburger-btn" aria-label="Open navigation menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>

    <!-- Mobile drawer -->
    <label for="mobile-drawer-toggle" class="drawer-backdrop" aria-hidden="true"></label>
    <nav class="drawer-panel" aria-label="Mobile navigation">
      <div class="drawer-header">
        <span class="brand-name">Jearon Wong</span>
        <label for="mobile-drawer-toggle" class="drawer-close" aria-label="Close navigation menu">&times;</label>
      </div>
      <ul class="drawer-list">
        {primaryNav.map(item => (
          <li>
            <a
              href={item.href}
              class:list={["drawer-link", currentPath === item.href.slice(0, -1) && "is-active"]}
            >{item.label}</a>
          </li>
        ))}
        <li class="drawer-divider"></li>
        {drawerSecondaryNav.map(item => (
          <li>
            <a
              href={item.href}
              class:list={["drawer-link", currentPath === item.href.slice(0, -1) && "is-active"]}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-monitor-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding-top: 0.45rem;
  }
  .monitor-shell {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 3.5rem;
    padding: 0.55rem 1.25rem;
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: blur(12px);
    border: none;
    border-bottom: 1px solid var(--border-registry);
  }

  .logo-link {
    text-decoration: none;
  }

  .brand-lockup {
    display: grid;
    gap: 0.1rem;
  }

  .brand-name {
    color: var(--text-registry-primary);
    font-family: var(--font-display);
    font-size: 1.06rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .brand-role {
    color: var(--text-registry-muted);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    line-height: 1.3;
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }
  
  .nav-list {
    display: flex;
    list-style: none;
    gap: 1.6rem;
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.15rem;
    transition: opacity 0.2s ease;
    text-decoration: none;
  }

  .nav-label {
    color: var(--text-registry-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  
  .nav-link:hover {
    opacity: 0.7;
  }

  .nav-link.is-active {
    opacity: 1;
  }

  .nav-link.is-active .nav-label {
    color: var(--text-registry-primary);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.42rem 0.9rem;
    border: 1px solid var(--border-registry);
    border-radius: var(--radius-module);
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .nav-cta:hover {
    border-color: var(--accent-signal);
  }

  .nav-cta-label {
    color: var(--text-registry-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Mobile Hamburger ── */
  .drawer-checkbox { display: none; }

  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    cursor: pointer;
    align-items: center;
    z-index: 1002;
  }
  .hamburger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-registry-primary);
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .drawer-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 1001;
  }

  .drawer-panel {
    position: fixed;
    top: 0;
    right: -320px;
    width: 300px;
    height: 100dvh;
    background: var(--bg-monolith);
    border-left: 1px solid var(--border-registry);
    z-index: 1003;
    padding: var(--registry-card-padding);
    transition: right 0.3s ease;
    overflow-y: auto;
    visibility: hidden;
  }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-registry);
    margin-bottom: var(--space-3);
  }
  .drawer-header .brand-name {
    font-size: 1rem;
  }
  .drawer-close {
    color: var(--text-registry-primary);
    font-size: 1.6rem;
    cursor: pointer;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .drawer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .drawer-link {
    display: block;
    padding: 0.9rem 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-registry-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--border-registry);
    transition: color 0.2s ease;
  }
  .drawer-link:hover,
  .drawer-link.is-active {
    color: var(--text-registry-primary);
  }
  .drawer-link--accent {
    font-weight: 700;
    color: var(--text-registry-primary);
  }
  .drawer-divider {
    height: 0;
    border-bottom: 1px solid var(--border-registry);
    margin: 0.5rem 0;
  }

  /* ── Checkbox-driven state ── */
  .drawer-checkbox:checked ~ .drawer-backdrop {
    display: block;
  }
  .drawer-checkbox:checked ~ .drawer-panel {
    right: 0;
    visibility: visible;
  }
  .drawer-checkbox:checked ~ .hamburger-btn .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .drawer-checkbox:checked ~ .hamburger-btn .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .drawer-checkbox:checked ~ .hamburger-btn .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 900px) {
    .nav-desktop, .nav-actions {
      display: none;
    }
    .hamburger-btn {
      display: flex;
    }
    .drawer-panel {
      visibility: hidden;
    }
  }

  @media (max-width: 640px) {
    .site-monitor-container {
      padding-top: 0.3rem;
    }

    .monitor-shell {
      min-height: 3.1rem;
      padding: 0.45rem 0.95rem;
    }

    .brand-name {
      font-size: 0.98rem;
    }

    .brand-role {
      font-size: 0.62rem;
    }

    .nav-cta {
      min-height: 2rem;
      padding: 0.35rem 0.72rem;
    }

    .nav-cta-label {
      font-size: 0.72rem;
    }
  }
</style>
