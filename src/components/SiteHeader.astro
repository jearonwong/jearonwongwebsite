---
import { primaryNav } from "../data/site";

const currentPath =
  Astro.url.pathname.length > 1 && Astro.url.pathname.endsWith("/")
    ? Astro.url.pathname.slice(0, -1)
    : Astro.url.pathname;
---

<header class="site-monitor-container">
  <div class="shell monitor-shell">
    <div class="logo">
      <a href="/" class="logo-link">
        <div class="brand-lockup">
          <span class="brand-name">Jearon Wang</span>
          <span class="brand-role">Protocol Architect for the Agent Era</span>
        </div>
      </a>
    </div>
    
    <nav class="nav-desktop">
      <ul class="nav-list">
        {primaryNav.map(item => (
          <li class="nav-item">
            <a
              href={item.href}
              class:list={["nav-link", currentPath === item.href.slice(0, -1) && "is-active"]}
            >
              <span class="nav-label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <a href="/contact/" class="nav-cta">
        <span class="nav-cta-label">Contact</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-monitor-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding-top: 0.6rem;
  }
  .monitor-shell {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 3.75rem;
    padding: 0.65rem 1.5rem;
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: blur(12px);
    border: none;
    border-bottom: 1px solid var(--border-registry);
  }

  .logo-link {
    text-decoration: none;
  }

  .brand-lockup {
    display: grid;
    gap: 0.1rem;
  }

  .brand-name {
    color: var(--text-registry-primary);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .brand-role {
    color: var(--text-registry-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  
  .nav-list {
    display: flex;
    list-style: none;
    gap: 1.6rem;
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    transition: opacity 0.2s ease;
    text-decoration: none;
  }

  .nav-label {
    color: var(--text-registry-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  
  .nav-link:hover {
    opacity: 0.7;
  }

  .nav-link.is-active {
    opacity: 1;
  }

  .nav-link.is-active .nav-label {
    color: var(--text-registry-primary);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.45rem 1rem;
    border: 1px solid var(--border-registry);
    border-radius: var(--radius-module);
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .nav-cta:hover {
    border-color: var(--accent-signal);
  }

  .nav-cta-label {
    color: var(--text-registry-primary);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
  }
</style>
