---
import { homepageContent } from "../data/site";
// Immediate Proof Signal
// Implements a strict architectural signal strip inside the first fold

const signals = homepageContent.stackMap.layers;
---

<div class="proof-signal">
  <span class="eyebrow signal-label">Stack Signal</span>
  <div class="proof-grid">
    {signals.map((signal) => (
      <div class="proof-item">
        <span class="proof-name">{signal.title}</span>
        <span class="proof-role">[{signal.stackLabel}]</span>
      </div>
    ))}
  </div>
</div>

<style>
  .proof-signal {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .signal-label {
    margin-bottom: 0;
    color: var(--zone-a-muted);
    font-size: 0.68rem;
  }
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem 1.5rem;
  }
  .proof-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-family: var(--font-mono);
    opacity: 0.95;
    min-width: 0;
  }
  .proof-name {
    color: var(--zone-a-text);
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .proof-role {
    color: var(--zone-a-muted);
    font-size: 0.76rem;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .proof-item {
      font-size: 0.78rem;
    }

    .proof-role {
      font-size: 0.72rem;
    }
  }
</style>
