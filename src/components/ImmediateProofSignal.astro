---
import { projects } from "../data/site";
// Immediate Proof Signal
// Implements a strict architectural signal strip inside the first fold
---

<div class="proof-signal">
  <span class="eyebrow signal-label">Proof Signal</span>
  <div class="proof-grid">
    {projects.map((project) => (
      <div class="proof-item">
        <span class="proof-name">{project.name}</span>
        <span class="proof-role">[{project.status}]</span>
      </div>
    ))}
  </div>
</div>

<style>
  .proof-signal {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .signal-label {
    margin-bottom: 0;
    color: var(--zone-a-muted);
  }
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem 2rem;
  }
  .proof-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    opacity: 0.95;
  }
  .proof-name {
    color: var(--zone-a-text);
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .proof-role {
    color: var(--zone-a-muted);
    font-size: 0.8rem;
  }
</style>
