---
import { projects } from "../data/site";
// Immediate Proof Signal
// Implements a strict architectural signal strip inside the first fold
---

<div class="proof-signal">
  <span class="eyebrow signal-label">Proof Signal</span>
  <ul class="proof-pills">
    {projects.map((project) => (
      <li class="proof-pill">
        <span class="proof-name">{project.name}</span>
        <span class="proof-role">[{project.status}]</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .proof-signal {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--current-border); /* Sharper top line */
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .signal-label {
    margin-bottom: 0;
    color: var(--zone-a-muted);
  }
  .proof-pills {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .proof-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    /* Removed the cozy pill background */
    padding: 0; 
    font-size: 0.85rem;
    font-family: var(--font-mono);
    opacity: 0.9;
  }
  .proof-pill:not(:last-child)::after {
    content: "·";
    color: var(--zone-a-border);
    margin-left: 0.35rem;
  }
  .proof-name {
    color: var(--current-text);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .proof-role {
    color: var(--current-muted);
  }
</style>
