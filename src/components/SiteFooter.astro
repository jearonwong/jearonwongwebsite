---
import { secondaryNav, siteConfig } from "../data/site";
---

<footer class="shell site-footer">
  <div class="footer-core">
    <div class="registry-annotation" style="margin-bottom: 0.6rem;">
      <span class="registry-key">SITE_STATE</span>: <span class="registry-value">PUBLIC_HEADQUARTERS</span>
    </div>
    <p class="footer-title">{siteConfig.author.name}</p>
    <p class="footer-meta">{siteConfig.author.role}</p>
    <p class="footer-copy">{siteConfig.author.bio}</p>
  </div>
  <nav aria-label="Secondary" class="secondary-nav">
    {secondaryNav.map((item) => (
      <a href={item.href} class="footer-link">{item.label}</a>
    ))}
  </nav>
</footer>

<style>
  .site-footer {
    padding: 6rem 0;
    display: grid;
    grid-template-columns: 1.1fr auto;
    gap: 4rem;
    align-items: start;
    border-top: 1px solid var(--current-line);
    margin-top: 4rem;
  }
  .footer-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    margin: 0;
    color: #0f172a;
    letter-spacing: -0.02em;
  }
  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-electric);
    margin: 0.5rem 0 2rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .footer-copy {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    color: #64748b;
    max-width: 38ch;
  }
  .secondary-nav {
    display: grid;
    grid-template-columns: repeat(2, auto);
    gap: 0.85rem 1.5rem;
    text-align: right;
  }
  .footer-link {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: var(--accent-kinetic);
  }
  @media (max-width: 640px) {
    .site-footer {
      padding: 3.5rem 0 0;
      grid-template-columns: 1fr;
      align-items: start;
      gap: 2rem;
    }
    .footer-title {
      font-size: 1.1rem;
    }
    .footer-meta {
      margin: 0.45rem 0 1.15rem;
      font-size: 0.7rem;
    }
    .footer-copy {
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .secondary-nav {
      text-align: left;
      gap: 0.7rem 1.1rem;
    }
    .footer-link {
      font-size: 0.75rem;
    }
  }
</style>
