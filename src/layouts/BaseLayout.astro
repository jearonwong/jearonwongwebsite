---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import { siteConfig, siteSemanticBaseline, socialLinks } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  shareTitle?: string;
  shareSubtitle?: string;
  shareDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  ogType?: "website" | "article";
  canonicalPath?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
  ogImagePath?: string;
  ogImageAlt?: string;
  twitterImagePath?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  shareTitle,
  shareDescription,
  twitterTitle,
  twitterDescription,
  ogType = "website",
  canonicalPath = Astro.url.pathname,
  noindex = false,
  jsonLd = [],
  ogImagePath = siteConfig.socialImagePath,
  ogImageAlt = `${siteConfig.author.name} — ${siteConfig.author.role}`,
  twitterImagePath
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.title}`;
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(ogImagePath, siteConfig.siteUrl).toString();
const twitterImageUrl = new URL(twitterImagePath ?? ogImagePath, siteConfig.siteUrl).toString();
const socialTitle = shareTitle ?? pageTitle;
const socialDescription = shareDescription ?? description;
const twitterCardTitle = twitterTitle ?? shareTitle ?? pageTitle;
const twitterCardDescription = twitterDescription ?? shareDescription ?? description;
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteConfig.siteUrl}#website`,
  url: siteConfig.siteUrl,
  name: siteConfig.title,
  description: siteConfig.description
});
const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteConfig.siteUrl}#person`,
  name: siteConfig.author.name,
  url: siteConfig.siteUrl,
  jobTitle: siteConfig.author.role,
  image: new URL(siteConfig.author.image, siteConfig.siteUrl).toString(),
  description: `${siteSemanticBaseline.identityAnchor}. ${siteSemanticBaseline.fieldDefinitionStatement} ${siteSemanticBaseline.agenticDeliveryDefinition}`,
  knowsAbout: [
    "AI Agent Lifecycle",
    "Agentic Delivery",
    "Multi-Agent Lifecycle Governance",
    "MPLP",
    "Confirmation Boundary",
    "Evidence Chain",
    "Semantic Loss",
    "Execution is not Delivery",
    "lifecycle protocol",
    "accountable outcomes",
    "accountable delivery",
    "Cognitive OS",
    "SoloCrew",
    "Validation Lab",
    "Lifecycle Role Decomposition",
    "Lifecycle-Governed Agent Workflow",
    "evidence adjudication",
    "protocol engineering",
    "agent governance",
    "production-grade AI agents",
    "AI agents",
    "multi-agent systems",
    "AI agent governance",
    "agent orchestration accountability",
    "AI agent infrastructure",
    "production AI agent systems"
  ],
  sameAs: socialLinks.map(l => l.href)
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#111418" />
    <meta name="author" content={siteConfig.author.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.xHandle} />
    <meta name="twitter:creator" content={siteConfig.xHandle} />
    <meta name="twitter:title" content={twitterCardTitle} />
    <meta name="twitter:description" content={twitterCardDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={twitterImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href="/rss.xml" />
    <script is:inline type="application/ld+json" set:html={websiteJsonLd}></script>
    <script is:inline type="application/ld+json" set:html={personJsonLd}></script>
    {jsonLd.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)}></script>
    ))}
  </head>
  <body class="zone-b">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main id="main-content" class="page-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
