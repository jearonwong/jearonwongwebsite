---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import { siteConfig, socialLinks } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  canonicalPath?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
  ogImagePath?: string;
  ogImageAlt?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogType = "website",
  canonicalPath = Astro.url.pathname,
  noindex = false,
  jsonLd = [],
  ogImagePath = siteConfig.socialImagePath,
  ogImageAlt = `${siteConfig.author.name} — ${siteConfig.author.role}`
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.title}`;
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(ogImagePath, siteConfig.siteUrl).toString();
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteConfig.siteUrl}#website`,
  url: siteConfig.siteUrl,
  name: siteConfig.title,
  description: siteConfig.description
});
const personJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteConfig.siteUrl}#person`,
  name: siteConfig.author.name,
  alternateName: "Jearon Wong",
  url: siteConfig.siteUrl,
  jobTitle: siteConfig.author.role,
  description: siteConfig.thesis,
  knowsAbout: [
    "AI agent reliability",
    "reliable AI agent delivery",
    "protocol engineering",
    "agent governance",
    "verifiable AI agents",
    "agent evidence chain",
    "AI agent lifecycle protocol",
    "governable agent systems"
  ],
  sameAs: socialLinks.map(l => l.href)
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#111418" />
    <meta name="author" content={siteConfig.author.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href="/rss.xml" />
    <script is:inline type="application/ld+json" set:html={websiteJsonLd}></script>
    <script is:inline type="application/ld+json" set:html={personJsonLd}></script>
    {jsonLd.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)}></script>
    ))}
  </head>
  <body class="zone-b">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main id="main-content" class="page-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
