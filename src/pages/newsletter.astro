---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { aiAgentLifecycleColumn, contentRouteRoles, newsletterPromise, pageRegistry, siteConfig } from "../data/site";

const essays = await getCollection("essays");
const lifecycleEssays = essays
  .filter((essay) => essay.data.series === aiAgentLifecycleColumn.seriesTitle)
  .sort((left, right) => right.data.publishDate.getTime() - left.data.publishDate.getTime());
const latestEssay = lifecycleEssays[0] ?? essays.find((essay) => essay.slug === aiAgentLifecycleColumn.firstPublishedEssay.slug);
const latestEssayCover = latestEssay?.data.images?.[0]?.url ?? aiAgentLifecycleColumn.coverImage;
const latestEssayCoverAlt = latestEssay?.data.images?.[0]?.alt ?? aiAgentLifecycleColumn.coverImageAlt;
---

<BaseLayout title="Newsletter" description={pageRegistry.newsletter.lead}>
  <RegistryPageHero
    title={pageRegistry.newsletter.title}
    objectType={pageRegistry.newsletter.objectType}
    objectValue={pageRegistry.newsletter.objectValue}
    lead={pageRegistry.newsletter.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell" style="max-width: 700px;">

      <!-- Subscribe form -->
      <article class="registry-chassis subscribe-block">
        <div class="registry-annotation" style="margin-bottom: 1.25rem;">
          <span class="registry-key">SUBSCRIBE</span>
        </div>
        <div class="registry-annotation route-question">
          <span class="registry-key">PAGE_QUESTION</span>: <span class="registry-value">{contentRouteRoles.newsletter.question}</span>
        </div>
        <p class="subscribe-desc">
          {newsletterPromise.headline}
        </p>
        <p class="subscribe-desc subscribe-desc--secondary">
          {newsletterPromise.cadence}
        </p>
        <ul class="topic-list" aria-label="Newsletter topics">
          {newsletterPromise.topics.map((topic) => (
            <li>{topic}</li>
          ))}
        </ul>
        <div class="column-note">
          <div class="registry-annotation" style="margin-bottom: 0.65rem;">
            <span class="registry-key">COLUMN_SIGNAL</span>: <span class="registry-value">{aiAgentLifecycleColumn.seriesTitle.toUpperCase()}</span>
          </div>
          <p>
            The first two essays are published. The next article will sharpen the field conflict between execution and delivery.
          </p>
          {latestEssay && (
            <a href={`/essays/${latestEssay.slug}/`} class="current-article-link">
              <img
                src={latestEssayCover}
                alt={latestEssayCoverAlt}
                width={latestEssay.data.images?.[0]?.width ?? 1200}
                height={latestEssay.data.images?.[0]?.height ?? 630}
                loading="lazy"
                decoding="async"
              />
              <span>
                <strong>{latestEssay.data.title}</strong>
                <small>{latestEssay.data.description}</small>
              </span>
            </a>
          )}
          <a href={aiAgentLifecycleColumn.href} class="column-link">Open the AI Agent Lifecycle field definition</a>
          <a href="/concepts/" class="column-link column-link--secondary">Open the Concepts map behind the series</a>
        </div>
        <form
          action={siteConfig.newsletterEndpoint}
          method="post"
          target="popupwindow"
          class="subscribe-form"
        >
          <label for="bd-email" class="visually-hidden">Email address</label>
          <input
            type="email"
            name="email"
            id="bd-email"
            placeholder="your@email.com"
            required
            class="subscribe-input"
          />
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </form>
        <div class="registry-annotation" style="margin-top: 1.5rem;">
          <span class="registry-key">FREQUENCY</span>: <span class="registry-value">WHEN THERE IS SUBSTANCE TO REPORT</span>
        </div>
        <p class="subscribe-boundary">{newsletterPromise.boundary}</p>
      </article>

      <!-- RSS alternative -->
      <article class="registry-chassis rss-block" style="margin-top: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">ALTERNATIVE</span>
        </div>
        <p class="rss-desc">Prefer RSS? Subscribe via your reader:</p>
        <a href="/rss.xml" class="rss-link">RSS FEED</a>
      </article>

    </section>
  </div>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
  .subscribe-block {
    padding: var(--registry-panel-padding);
  }
  .route-question {
    margin-bottom: 1.25rem;
  }
  .subscribe-desc {
    margin: 0 0 1rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--current-muted);
    max-width: 50ch;
  }
  .subscribe-desc--secondary {
    margin-bottom: 1.5rem;
    font-size: 0.98rem;
  }
  .topic-list {
    display: grid;
    gap: 0.65rem;
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
  }
  .topic-list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--current-muted);
  }
  .topic-list li::before {
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.36rem;
    height: 0.36rem;
    content: "";
    background: var(--accent-signal);
    border-radius: 999px;
  }
  .column-note {
    margin: 0 0 2rem;
    padding: 1rem;
    border: 1px solid var(--current-line);
  }
  .column-note p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--current-muted);
  }
  .current-article-link {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr);
    gap: 0.85rem;
    align-items: center;
    margin-top: 1rem;
    color: var(--current-text);
    text-decoration: none;
  }
  .current-article-link img {
    width: 100%;
    height: auto;
    border: 1px solid var(--current-line);
    background: #111111;
  }
  .current-article-link span {
    display: grid;
    gap: 0.25rem;
  }
  .current-article-link strong {
    font-size: 0.95rem;
    line-height: 1.3;
  }
  .current-article-link small {
    color: var(--current-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }
  .current-article-link:hover strong {
    color: var(--accent-signal);
  }
  .column-link {
    display: inline-flex;
    margin-top: 0.85rem;
    margin-right: 1rem;
    color: var(--accent-signal);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .column-link:hover {
    color: var(--current-text);
  }
  .column-link--secondary {
    color: var(--current-text);
  }
  .subscribe-form {
    display: flex;
    gap: 0;
  }
  .subscribe-input {
    flex: 1;
    padding: 0.8rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-right: none;
    border-radius: 2px 0 0 2px;
    background: white;
    color: #111;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .subscribe-input:focus {
    border-color: var(--accent-signal);
  }
  .subscribe-input::placeholder {
    color: #94a3b8;
  }
  .subscribe-btn {
    padding: 0.8rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--accent-signal);
    color: white;
    border: 1px solid var(--accent-signal);
    border-radius: 0 2px 2px 0;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .subscribe-btn:hover {
    opacity: 0.85;
  }
  .subscribe-boundary {
    margin: 0.8rem 0 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--current-muted);
  }
  .rss-block {
    padding: var(--registry-card-padding);
  }
  .rss-desc {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: var(--current-muted);
  }
  .rss-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--current-text);
    border: 1px solid var(--current-border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }
  .rss-link:hover {
    border-color: var(--accent-signal);
    color: var(--accent-signal);
  }
  @media (max-width: 640px) {
    .subscribe-block, .rss-block {
      padding: var(--registry-card-padding);
    }
    .subscribe-form {
      flex-direction: column;
      gap: 0.6rem;
    }
    .subscribe-input {
      border-right: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 2px;
    }
    .subscribe-btn {
      border-radius: 2px;
    }
    .current-article-link {
      grid-template-columns: 1fr;
    }
  }
</style>
