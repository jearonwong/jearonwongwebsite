---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { contentRouteRoles, newsletterPromise, pageRegistry, siteConfig } from "../data/site";
---

<BaseLayout title="Newsletter" description={pageRegistry.newsletter.lead}>
  <RegistryPageHero
    title={pageRegistry.newsletter.title}
    objectType={pageRegistry.newsletter.objectType}
    objectValue={pageRegistry.newsletter.objectValue}
    lead={pageRegistry.newsletter.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell" style="max-width: 700px;">

      <!-- Subscribe form -->
      <article class="registry-chassis subscribe-block">
        <div class="registry-annotation" style="margin-bottom: 1.25rem;">
          <span class="registry-key">SUBSCRIBE</span>
        </div>
        <div class="registry-annotation route-question">
          <span class="registry-key">PAGE_QUESTION</span>: <span class="registry-value">{contentRouteRoles.newsletter.question}</span>
        </div>
        <p class="subscribe-desc">
          {newsletterPromise.headline}
        </p>
        <p class="subscribe-desc subscribe-desc--secondary">
          {newsletterPromise.cadence}
        </p>
        <ul class="topic-list" aria-label="Newsletter topics">
          {newsletterPromise.topics.map((topic) => (
            <li>{topic}</li>
          ))}
        </ul>
        <form
          action={siteConfig.newsletterEndpoint}
          method="post"
          target="popupwindow"
          class="subscribe-form"
        >
          <label for="bd-email" class="visually-hidden">Email address</label>
          <input
            type="email"
            name="email"
            id="bd-email"
            placeholder="your@email.com"
            required
            class="subscribe-input"
          />
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </form>
        <div class="registry-annotation" style="margin-top: 1.5rem;">
          <span class="registry-key">FREQUENCY</span>: <span class="registry-value">WHEN THERE IS SUBSTANCE TO REPORT</span>
        </div>
        <p class="subscribe-boundary">{newsletterPromise.boundary}</p>
      </article>

      <!-- RSS alternative -->
      <article class="registry-chassis rss-block" style="margin-top: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">ALTERNATIVE</span>
        </div>
        <p class="rss-desc">Prefer RSS? Subscribe via your reader:</p>
        <a href="/rss.xml" class="rss-link">RSS FEED</a>
      </article>

    </section>
  </div>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
  .subscribe-block {
    padding: 2.5rem;
  }
  .route-question {
    margin-bottom: 1.25rem;
  }
  .subscribe-desc {
    margin: 0 0 1rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--current-muted);
    max-width: 50ch;
  }
  .subscribe-desc--secondary {
    margin-bottom: 1.5rem;
    font-size: 0.98rem;
  }
  .topic-list {
    display: grid;
    gap: 0.65rem;
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
  }
  .topic-list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--current-muted);
  }
  .topic-list li::before {
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.36rem;
    height: 0.36rem;
    content: "";
    background: var(--accent-signal);
    border-radius: 999px;
  }
  .subscribe-form {
    display: flex;
    gap: 0;
  }
  .subscribe-input {
    flex: 1;
    padding: 0.8rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-right: none;
    border-radius: 2px 0 0 2px;
    background: white;
    color: #111;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .subscribe-input:focus {
    border-color: var(--accent-signal);
  }
  .subscribe-input::placeholder {
    color: #94a3b8;
  }
  .subscribe-btn {
    padding: 0.8rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--accent-signal);
    color: white;
    border: 1px solid var(--accent-signal);
    border-radius: 0 2px 2px 0;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .subscribe-btn:hover {
    opacity: 0.85;
  }
  .subscribe-boundary {
    margin: 0.8rem 0 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--current-muted);
  }
  .rss-block {
    padding: 2rem 2.5rem;
  }
  .rss-desc {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: var(--current-muted);
  }
  .rss-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--current-text);
    border: 1px solid var(--current-border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }
  .rss-link:hover {
    border-color: var(--accent-signal);
    color: var(--accent-signal);
  }
  @media (max-width: 640px) {
    .subscribe-block, .rss-block {
      padding: 1.75rem;
    }
    .subscribe-form {
      flex-direction: column;
      gap: 0.6rem;
    }
    .subscribe-input {
      border-right: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 2px;
    }
    .subscribe-btn {
      border-radius: 2px;
    }
  }
</style>
