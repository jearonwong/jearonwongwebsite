---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { pageRegistry } from "../data/site";
---

<BaseLayout title="Newsletter">
  <RegistryPageHero
    title={pageRegistry.newsletter.title}
    objectType={pageRegistry.newsletter.objectType}
    objectValue={pageRegistry.newsletter.objectValue}
    lead={pageRegistry.newsletter.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <article class="registry-chassis appendix-panel">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">STATUS</span>: <span class="registry-value">PLACEHOLDER_ONLY</span>
        </div>
        <p class="appendix-body">
          The newsletter route exists now as a stable subscription destination, but the delivery
          mechanism remains intentionally lightweight in this static-first release.
        </p>
      </article>
    </section>
  </div>
</BaseLayout>

<style>
  .appendix-panel {
    padding: 2.5rem;
  }
  .appendix-body {
    max-width: 62ch;
    margin: 0;
    color: var(--current-muted);
    line-height: 1.7;
    font-size: 1.05rem;
  }
</style>
