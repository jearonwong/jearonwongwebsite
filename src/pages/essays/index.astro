---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryPageHero from "../../components/RegistryPageHero.astro";
import { contentRouteRoles, getTheoryClusterName, pageRegistry } from "../../data/site";

const essays = (await getCollection("essays")).sort(
  (left, right) =>
    Number(right.data.flagship) - Number(left.data.flagship) ||
    right.data.publishDate.getTime() - left.data.publishDate.getTime()
);
---

<BaseLayout title="Essays" description={pageRegistry.essays.lead}>
  <RegistryPageHero
    title={pageRegistry.essays.title}
    objectType={pageRegistry.essays.objectType}
    objectValue={pageRegistry.essays.objectValue}
    lead={pageRegistry.essays.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis start-here-block">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">READING_PATH</span>: <span class="registry-value">{contentRouteRoles.essays.question}</span>
        </div>
        <div class="start-here-links">
          <a href="/essays/mcp-connects-tools-a2a-connects-agents-who-governs-the-lifecycle/" class="start-link">
            <span class="start-index">01</span>
            <span class="start-copy">
              <strong>Lifecycle governance / MCP-A2A gap</strong>
              <span>Start with the protocol-stack question: tool access and agent coordination still need lifecycle authority.</span>
            </span>
          </a>
          <a href="/essays/agentic-ai-inflection-point-project-delivery/" class="start-link">
            <span class="start-index">02</span>
            <span class="start-copy">
              <strong>Agentic Delivery / project delivery</strong>
              <span>Then read the category argument: agent systems must move from task execution to reliable project delivery.</span>
            </span>
          </a>
        </div>
      </div>

      <div class="registry-log">
        {essays.map((essay) => (
          <article class:list={["log-entry", essay.data.flagship && "is-flagship"]}>
            <div class="log-metadata">
              {essay.data.flagship && (
                <div class="registry-annotation log-flagship">
                  <span class="registry-key">START_HERE</span>: <span class="registry-value">FLAGSHIP ESSAY</span>
                </div>
              )}
              <div class="registry-annotation">
                <span class="registry-key">ENTRY_DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
              </div>
              <div class="registry-annotation">
                <span class="registry-key">IDEA</span>: <span class="registry-value">{getTheoryClusterName(essay.data.cluster).toUpperCase()}</span>
              </div>
            </div>
            <div class="log-content">
              <h3 class="log-title"><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
              <p class="log-desc">{essay.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .start-here-block {
    margin-bottom: 2rem;
    padding: 2rem;
  }
  .start-here-links {
    display: grid;
    gap: 0.85rem;
  }
  .start-link {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    padding: 1rem 0;
    color: var(--current-text);
    text-decoration: none;
    border-top: 1px solid var(--current-line);
  }
  .start-link:last-child {
    border-bottom: 1px solid var(--current-line);
  }
  .start-link:hover strong {
    color: var(--accent-signal);
  }
  .start-index {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    color: var(--accent-signal);
    letter-spacing: 0.06em;
  }
  .start-copy {
    display: grid;
    gap: 0.35rem;
  }
  .start-copy strong {
    font-size: 1rem;
    line-height: 1.3;
    transition: color 0.2s ease;
  }
  .start-copy span {
    max-width: 68ch;
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--current-muted);
  }
  .registry-log {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--current-line);
  }
  .log-entry {
    display: grid;
    grid-template-columns: 280px 1fr;
    padding: 3rem;
    border-bottom: 1px solid var(--current-line);
    transition: background-color 0.25s ease;
  }
  .log-entry:last-child {
    border-bottom: none;
  }
  .log-entry:hover {
    background-color: rgba(59, 130, 246, 0.03);
  }
  .log-entry.is-flagship {
    border-left: 2px solid var(--accent-signal);
  }
  .log-metadata {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .log-flagship {
    color: var(--accent-signal);
  }
  .log-title {
    font-size: 1.72rem;
    font-weight: 800;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .log-title a {
    color: var(--current-text);
    text-decoration: none;
  }
  .log-title a:hover {
    color: var(--accent-signal);
  }
  .log-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
    max-width: 62ch;
    margin: 0;
  }
  @media (max-width: 900px) {
    .start-here-block {
      padding: 1.5rem;
    }
    .start-link {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .log-entry {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      padding: 1.75rem;
    }
    .log-metadata {
      gap: 0.65rem;
    }
    .log-title {
      font-size: 1.4rem;
    }
    .log-desc {
      font-size: 0.95rem;
    }
  }
</style>
