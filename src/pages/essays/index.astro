---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryPageHero from "../../components/RegistryPageHero.astro";
import { aiAgentLifecycleColumn, pageRegistry } from "../../data/site";

const essays = (await getCollection("essays")).sort(
  (left, right) =>
    Number(right.data.flagship) - Number(left.data.flagship) ||
    right.data.publishDate.getTime() - left.data.publishDate.getTime()
);
const essaysBySlug = new Map(essays.map((essay) => [essay.slug, essay]));
const lifecycleEssays = essays.filter((essay) => essay.data.series === aiAgentLifecycleColumn.seriesTitle);
const firstColumnEssay = essaysBySlug.get(aiAgentLifecycleColumn.firstPublishedEssay.slug);
const spotlightEssay = lifecycleEssays[0] ?? firstColumnEssay;
const columnCover = spotlightEssay?.data.images?.[0]?.url ?? aiAgentLifecycleColumn.coverImage;
const columnCoverAlt = spotlightEssay?.data.images?.[0]?.alt ?? aiAgentLifecycleColumn.coverImageAlt;
const foundationEssays = ["agentic-ai-inflection-point-project-delivery"]
  .map((slug) => essaysBySlug.get(slug))
  .filter((essay): essay is NonNullable<typeof essay> => Boolean(essay));
const protocolEssays = ["mcp-connects-tools-a2a-connects-agents-who-governs-the-lifecycle"]
  .map((slug) => essaysBySlug.get(slug))
  .filter((essay): essay is NonNullable<typeof essay> => Boolean(essay));
---

<BaseLayout title="Essays" description={pageRegistry.essays.lead}>
  <RegistryPageHero
    title={pageRegistry.essays.title}
    objectType={pageRegistry.essays.objectType}
    objectValue={pageRegistry.essays.objectValue}
    lead={pageRegistry.essays.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell">
      <div class="registry-chassis lifecycle-spotlight">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">COLUMN</span>: <span class="registry-value">{aiAgentLifecycleColumn.seriesTitle.toUpperCase()}</span>
        </div>
        <div class="lifecycle-spotlight-grid">
          {spotlightEssay && (
            <a href={`/essays/${spotlightEssay.slug}/`} class="spotlight-cover" aria-label={`Read ${spotlightEssay.data.title}`}>
              <img
                src={columnCover}
                alt={columnCoverAlt}
                width={spotlightEssay.data.images?.[0]?.width ?? 1200}
                height={spotlightEssay.data.images?.[0]?.height ?? 630}
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
          <div class="spotlight-main">
            <h2 class="spotlight-title">{aiAgentLifecycleColumn.categoryTitle}</h2>
            <p class="spotlight-copy">Execution is not Delivery. These essays develop the argument. Use /lifecycle/ for the theory entry; use this page for the writing order.</p>
            {spotlightEssay && (
              <div class="current-essay">
                <span class="current-essay-label">Latest published column essay</span>
                <h3><a href={`/essays/${spotlightEssay.slug}/`}>{spotlightEssay.data.title}</a></h3>
                <p>{spotlightEssay.data.description}</p>
              </div>
            )}
          </div>
          <div class="spotlight-actions">
            <p>{aiAgentLifecycleColumn.nextEssayDirection}</p>
            <a href={aiAgentLifecycleColumn.href} class="spotlight-link">Open Lifecycle mainline</a>
            <a href="/concepts/" class="spotlight-link">Concepts reference</a>
            {firstColumnEssay && <a href={`/essays/${firstColumnEssay.slug}/`} class="spotlight-link">Read essay 01</a>}
            {spotlightEssay && spotlightEssay.slug !== firstColumnEssay?.slug && (
              <a href={`/essays/${spotlightEssay.slug}/`} class="spotlight-link">Read latest essay</a>
            )}
          </div>
        </div>
      </div>

      <div class="essay-sections">
        <section class="essay-section">
          <div class="registry-section-heading">
            <div class="registry-annotation" style="margin-bottom: 0.65rem;">
              <span class="registry-key">SEQUENCE</span>: <span class="registry-value">DEFINE THE AI AGENT LIFECYCLE</span>
            </div>
            <h2>Define The AI Agent Lifecycle</h2>
          </div>
          <div class="registry-log">
            {lifecycleEssays.map((essay) => (
              <article class="log-entry is-series">
                <div class="log-metadata">
                  <div class="registry-annotation log-series">
                    <span class="registry-key">SERIES</span>: <span class="registry-value">#{essay.data.seriesOrder ?? 1}</span>
                  </div>
                  <div class="registry-annotation">
                    <span class="registry-key">ENTRY_DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
                  </div>
                </div>
                <div class="log-content">
                  <h3 class="log-title"><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
                  <p class="log-desc">{essay.data.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="essay-section">
          <div class="registry-section-heading">
            <div class="registry-annotation" style="margin-bottom: 0.65rem;">
              <span class="registry-key">SEQUENCE</span>: <span class="registry-value">FOUNDATION ESSAYS</span>
            </div>
            <h2>Foundation Essays</h2>
          </div>
          <div class="registry-log">
            {foundationEssays.map((essay) => (
              <article class="log-entry">
                <div class="log-metadata">
                  <div class="registry-annotation">
                    <span class="registry-key">ROLE</span>: <span class="registry-value">AGENTIC DELIVERY THESIS</span>
                  </div>
                  <div class="registry-annotation">
                    <span class="registry-key">ENTRY_DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
                  </div>
                </div>
                <div class="log-content">
                  <h3 class="log-title"><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
                  <p class="log-desc">{essay.data.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="essay-section">
          <div class="registry-section-heading">
            <div class="registry-annotation" style="margin-bottom: 0.65rem;">
              <span class="registry-key">SEQUENCE</span>: <span class="registry-value">PROTOCOL / GOVERNANCE ESSAYS</span>
            </div>
            <h2>Protocol / Governance Essays</h2>
          </div>
          <div class="registry-log">
            {protocolEssays.map((essay) => (
              <article class:list={["log-entry", essay.data.flagship && "is-flagship"]}>
                <div class="log-metadata">
                  {essay.data.flagship && (
                    <div class="registry-annotation log-flagship">
                      <span class="registry-key">START_HERE</span>: <span class="registry-value">FLAGSHIP ESSAY</span>
                    </div>
                  )}
                  <div class="registry-annotation">
                    <span class="registry-key">ENTRY_DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
                  </div>
                </div>
                <div class="log-content">
                  <h3 class="log-title"><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
                  <p class="log-desc">{essay.data.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .lifecycle-spotlight {
    margin-bottom: var(--space-4);
    padding: var(--registry-panel-padding);
    border-left: 2px solid var(--accent-proof);
  }
  .lifecycle-spotlight-grid {
    display: grid;
    grid-template-columns: minmax(240px, 0.72fr) minmax(0, 1fr) minmax(240px, 0.58fr);
    gap: 2rem;
    align-items: start;
  }
  .spotlight-cover {
    display: block;
    border: 1px solid var(--current-line);
    background: #111111;
    text-decoration: none;
  }
  .spotlight-cover img {
    width: 100%;
    height: auto;
  }
  .spotlight-main {
    min-width: 0;
  }
  .spotlight-title {
    margin: 0 0 0.7rem;
    font-size: 1.8rem;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .spotlight-copy,
  .spotlight-relation,
  .spotlight-actions p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--current-muted);
  }
  .spotlight-relation {
    margin-top: 0.9rem;
    color: var(--current-text);
  }
  .spotlight-actions {
    display: grid;
    align-content: start;
    gap: 1rem;
  }
  .current-essay {
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--current-line);
  }
  .current-essay-label,
  .foundation-label {
    display: block;
    margin-bottom: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-proof);
  }
  .current-essay h3 {
    margin: 0 0 0.55rem;
    font-size: 1.2rem;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }
  .current-essay h3 a {
    color: var(--current-text);
    text-decoration: none;
  }
  .current-essay h3 a:hover {
    color: var(--accent-signal);
  }
  .current-essay p {
    margin: 0;
    color: var(--current-muted);
    font-size: 0.92rem;
    line-height: 1.58;
  }
  .foundation-strip {
    display: grid;
    grid-template-columns: minmax(160px, 0.32fr) repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.6rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--current-line);
  }
  .foundation-strip a {
    display: grid;
    gap: 0.35rem;
    color: var(--current-text);
    text-decoration: none;
  }
  .foundation-strip a:hover strong {
    color: var(--accent-signal);
  }
  .foundation-strip strong {
    font-size: 0.95rem;
    line-height: 1.35;
  }
  .foundation-strip span:not(.foundation-label) {
    color: var(--current-muted);
    font-size: 0.84rem;
    line-height: 1.45;
  }
  .spotlight-link {
    display: inline-flex;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .spotlight-link:hover {
    color: var(--current-text);
  }

  .essay-sections {
    display: grid;
    gap: var(--space-8);
  }

  .essay-section {
    display: grid;
    gap: var(--space-4);
  }

  .registry-section-heading {
    margin: 0;
  }
  .registry-section-heading h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }
  .registry-log {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--current-line);
  }
  .log-entry {
    display: grid;
    grid-template-columns: 280px 1fr;
    padding: var(--registry-panel-padding);
    border-bottom: 1px solid var(--current-line);
    transition: background-color 0.25s ease;
  }
  .log-entry:last-child {
    border-bottom: none;
  }
  .log-entry:hover {
    background-color: rgba(59, 130, 246, 0.03);
  }
  .log-entry.is-flagship {
    border-left: 2px solid var(--accent-signal);
  }
  .log-entry.is-series {
    border-left: 2px solid var(--accent-proof);
  }
  .log-metadata {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .log-flagship {
    color: var(--accent-signal);
  }
  .log-series {
    color: var(--accent-proof);
  }
  .log-title {
    font-size: 1.72rem;
    font-weight: 800;
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .log-title a {
    color: var(--current-text);
    text-decoration: none;
  }
  .log-title a:hover {
    color: var(--accent-signal);
  }
  .log-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
    max-width: 62ch;
    margin: 0;
  }
  @media (max-width: 900px) {
    .lifecycle-spotlight {
      padding: var(--registry-card-padding);
    }
    .lifecycle-spotlight-grid {
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }
    .spotlight-title {
      font-size: 1.45rem;
    }
    .foundation-strip {
      grid-template-columns: 1fr;
    }
    .log-entry {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      padding: var(--registry-card-padding);
    }
    .log-metadata {
      gap: 0.65rem;
    }
    .log-title {
      font-size: 1.4rem;
    }
    .log-desc {
      font-size: 0.95rem;
    }
  }
</style>
