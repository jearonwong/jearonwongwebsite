---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { siteConfig } from "../../data/site";

const essays = (await getCollection("essays")).sort(
  (left, right) => right.data.publishDate.getTime() - left.data.publishDate.getTime()
);
---

<BaseLayout title={`Registry | ${siteConfig.title}`}>
  <div class="zone-a registry-grid" style="padding-top: 10rem; padding-bottom: 6rem; border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    <div class="shell">
      <div class="registry-annotation" style="margin-bottom: 1rem;">
        <span class="registry-key">OBJECT_TYPE</span>: <span class="registry-value">REGISTRY_LOGBOOK</span>
      </div>
      <h1 class="registry-title">REGISTRY_LOGBOOK</h1>
      <p class="lead registry-lead-desc">A chronologically ordered ledger of protocol iterations, architectural decisions, and system state observations.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-log">
        {essays.map(essay => (
          <article class="log-entry">
            <div class="log-metadata">
              <div class="registry-annotation">
                <span class="registry-key">ENTRY_DATE</span>: <span class="registry-value">{essay.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
              </div>
              <div class="registry-annotation">
                <span class="registry-key">ID</span>: <span class="registry-value">{essay.slug.toUpperCase()}</span>
              </div>
            </div>
            <div class="log-content">
              <h3 class="log-title"><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
              <p class="log-desc">{essay.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .registry-title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }
  .registry-lead-desc {
    max-width: 55ch;
    font-size: 1.25rem;
    color: var(--text-registry-muted);
    border-left: 2px solid var(--border-registry);
    padding-left: 1.5rem;
  }
  .registry-log {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--current-line);
  }
  .log-entry {
    display: grid;
    grid-template-columns: 280px 1fr;
    padding: 3.5rem;
    border-bottom: 1px solid var(--current-line);
    transition: all 0.3s ease;
  }
  .log-entry:last-child {
    border-bottom: none;
  }
  .log-entry:hover {
    background-color: rgba(59, 130, 246, 0.03);
    border-left: 4px solid var(--accent-signal);
    padding-left: calc(3.5rem - 4px);
  }
  .log-metadata {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .log-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .log-title a {
    color: var(--current-text);
    text-decoration: none;
  }
  .log-title a:hover {
    color: var(--accent-signal);
  }
  .log-desc {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--current-muted);
    max-width: 65ch;
  }
  @media (max-width: 900px) {
    .log-entry {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem;
    }
    .log-entry:hover {
      padding-left: 2rem;
    }
  }
</style>
