---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { aiAgentLifecycleColumn, getConceptBySlug, getProjectBySlug, pageRegistry, siteSemanticBaseline } from "../data/site";

const essays = await getCollection("essays");
const essaysBySlug = new Map(essays.map((essay) => [essay.slug, essay]));
const firstEssay = essaysBySlug.get(aiAgentLifecycleColumn.firstPublishedEssay.slug);
const preludeEntries = aiAgentLifecycleColumn.preludeEssays
  .map((entry) => {
    const essay = essaysBySlug.get(entry.slug);
    return essay ? { ...entry, essay } : null;
  })
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));
const firstEssayCover = firstEssay?.data.images?.[0]?.url ?? aiAgentLifecycleColumn.coverImage;
const firstEssayCoverAlt = firstEssay?.data.images?.[0]?.alt ?? aiAgentLifecycleColumn.coverImageAlt;
const lifecycleConcept = getConceptBySlug("ai-agent-lifecycle");
const failureModeConcepts = ["intent-drift", "context-drift", "confirmation-boundary", "lifecycle-evidence"]
  .map((conceptSlug) => getConceptBySlug(conceptSlug))
  .filter((concept): concept is NonNullable<typeof concept> => Boolean(concept));
const proofStack = ["mplp", "cognitive-os", "solocrew", "validation-lab"]
  .map((projectSlug) => getProjectBySlug(projectSlug))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));
const relationshipMap = [
  {
    label: "Agentic Delivery",
    role: "Outcome thesis",
    body: siteSemanticBaseline.agenticDeliveryDefinition
  },
  {
    label: "AI Agent Lifecycle",
    role: "Continuity / work-state layer",
    body: "The layer that keeps intent, context, role, plan, confirmation, execution, evidence, learning, and acceptance continuous."
  },
  {
    label: "Agentic Delivery Stack",
    role: "Reference architecture",
    body: siteSemanticBaseline.agenticDeliveryStackDefinition
  },
  {
    label: "MPLP",
    role: "Lifecycle protocol",
    body: siteSemanticBaseline.mplpDefinition
  },
  {
    label: "Cognitive OS / SoloCrew / Validation Lab",
    role: "Concrete reference path",
    body: "Together with MPLP, these proof objects form a concrete reference path through Agentic Delivery without closing the category."
  }
];
---

<BaseLayout title={pageRegistry.lifecycle.title} description={aiAgentLifecycleColumn.categoryStatement}>
  <RegistryPageHero
    title={aiAgentLifecycleColumn.categoryTitle}
    subtitle={aiAgentLifecycleColumn.subtitle}
    objectType={pageRegistry.lifecycle.objectType}
    objectValue={pageRegistry.lifecycle.objectValue}
    lead={aiAgentLifecycleColumn.categoryStatement}
  >
    <div class="lifecycle-hero-links">
      <a href="/essays/" class="registry-annotation lifecycle-hero-link">
        <span class="registry-key">ESSAYS</span>: <span class="registry-value">PUBLIC ARGUMENTS</span>
      </a>
      <a href="/projects/mplp/" class="registry-annotation lifecycle-hero-link">
        <span class="registry-key">MPLP</span>: <span class="registry-value">LIFECYCLE PROTOCOL</span>
      </a>
    </div>
  </RegistryPageHero>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <div class="shell lifecycle-shell">
      <section class="registry-chassis lifecycle-opening lifecycle-opening--main">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">CANONICAL_DEFINITION</span>: <span class="registry-value">MAINLINE</span>
        </div>
        <div class="opening-grid">
          <div>
            <h2>AI Agent Lifecycle is the work-continuity layer.</h2>
            <p>{lifecycleConcept?.definition ?? aiAgentLifecycleColumn.purpose}</p>
          </div>
          <div class="opening-notes">
            <p>{aiAgentLifecycleColumn.relationToAgenticDelivery}</p>
            <p>{aiAgentLifecycleColumn.categoryBridge}</p>
            <p>{aiAgentLifecycleColumn.relationToMPLP}</p>
          </div>
        </div>
      </section>

      <section class="lifecycle-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">RELATIONSHIP_MAP</span>: <span class="registry-value">THESIS_TO_PROOF</span>
          </div>
          <h2>The spine of the site.</h2>
          <p class="section-desc">Jearon Wong defines AI Agent Lifecycle, explains Agentic Delivery and the Agentic Delivery Stack, names the failure modes, and routes the proof through MPLP, Cognitive OS, SoloCrew, and Validation Lab.</p>
        </div>
        <div class="relationship-grid">
          {relationshipMap.map((item) => (
            <article class="registry-chassis lifecycle-card lifecycle-card--relation">
              <span class="relation-role">{item.role}</span>
              <h3>{item.label}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="lifecycle-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">PREVIEW</span>: <span class="registry-value">FOUR LAYERS</span>
          </div>
          <h2>Four lifecycle layers.</h2>
          <p class="section-desc">A concise map of the work boundary. The essays develop the argument; this page keeps the reader on the main route.</p>
        </div>
        <div class="lifecycle-card-grid">
          {aiAgentLifecycleColumn.lifecycleLayers.map((layer) => (
            <article class="registry-chassis lifecycle-card">
              <h3>{layer.name}</h3>
              <p>{layer.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="lifecycle-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">FAILURE_MODES</span>: <span class="registry-value">REFERENCE LAYER</span>
          </div>
          <h2>Core lifecycle failure modes.</h2>
          <p class="section-desc">These are the first reference concepts to name the weak points in long-running agent work. The full definitions stay in Concepts.</p>
        </div>
        <div class="failure-grid">
          {failureModeConcepts.map((concept) => (
            <a href={`/concepts/${concept.slug}/`} class="registry-chassis failure-card">
              <h3>{concept.term}</h3>
              <p>{concept.seoDescription}</p>
            </a>
          ))}
        </div>
      </section>

      {firstEssay && (
        <section class="registry-chassis first-essay-panel">
          <a href={`/essays/${firstEssay.slug}/`} class="first-essay-cover" aria-label={`Read ${firstEssay.data.title}`}>
            <img src={firstEssayCover} alt={firstEssayCoverAlt} width="1200" height="630" loading="lazy" decoding="async" />
          </a>
          <div class="first-essay-copy">
            <div class="registry-annotation" style="margin-bottom: 0.8rem;">
              <span class="registry-key">START_READING</span>: <span class="registry-value">LIFECYCLE ESSAY 01</span>
            </div>
            <h2>{firstEssay.data.title}</h2>
            <p>{firstEssay.data.description}</p>
            <p class="first-essay-note">{aiAgentLifecycleColumn.nextEssayDirection}</p>
            <div class="start-link-stack">
              <a href={`/essays/${firstEssay.slug}/`} class="lifecycle-text-link">Read essay 01</a>
              <a href="/essays/" class="lifecycle-text-link">Open essays index</a>
            </div>
          </div>
        </section>
      )}

      <section class="lifecycle-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">PROOF_STACK</span>: <span class="registry-value">LEDGER ROUTE</span>
          </div>
          <h2>Proof stack route.</h2>
          <p class="section-desc">The proof stack stays in order: lifecycle protocol, runtime path, delivery proof path, evidence adjudication.</p>
          <a href="/projects/" class="lifecycle-text-link">Open Projects proof ledger</a>
        </div>
        <div class="proof-route-grid">
          {proofStack.map((project) => (
            <a href={`/projects/${project.slug}/`} class="registry-chassis proof-route-card">
              <span>{project.proofRole}</span>
              <h3>{project.name}</h3>
              <p>{project.summary}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="registry-chassis lifecycle-concepts">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">REFERENCE_LAYER</span>: <span class="registry-value">CONCEPTS</span>
        </div>
        <div class="opening-grid">
          <div>
            <h2>Concepts remains the reference layer.</h2>
            <p>
              This Lifecycle page is the human-visible main route. Concepts remains the canonical definition layer for search engines, AI readers, and readers who want term-level references.
            </p>
          </div>
          <div class="concept-link-stack">
            <a href="/concepts/" class="lifecycle-text-link">Open Concepts reference</a>
            <a href="/concepts/ai-agent-lifecycle/" class="lifecycle-text-link">AI Agent Lifecycle definition</a>
            <a href="/concepts/agentic-delivery/" class="lifecycle-text-link">Agentic Delivery definition</a>
          </div>
        </div>
      </section>

      <section class="lifecycle-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">SERIES_STATE</span>: <span class="registry-value">FOUNDATION</span>
          </div>
          <h2>{aiAgentLifecycleColumn.seriesTitle}</h2>
          <p class="section-desc">{aiAgentLifecycleColumn.publicationRule}</p>
        </div>

        {preludeEntries.length > 0 && (
          <div class="prelude-list" aria-label="Prelude essays">
            {preludeEntries.map((entry, index) => (
              <a href={`/essays/${entry.essay.slug}/`} class="prelude-link">
                <span class="prelude-index">{String(index + 1).padStart(2, "0")}</span>
                <span class="prelude-copy">
                  <strong>{entry.essay.data.title}</strong>
                  <span>{entry.role}</span>
                </span>
              </a>
            ))}
          </div>
        )}

        <article class="registry-chassis next-essay-card">
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">NEXT_ESSAY</span>: <span class="registry-value">{aiAgentLifecycleColumn.nextEssay.status.toUpperCase()}</span>
          </div>
          <h3>{aiAgentLifecycleColumn.nextEssay.title}</h3>
        </article>
      </section>

      <section class="registry-chassis newsletter-cta">
        <div>
          <div class="registry-annotation" style="margin-bottom: 0.8rem;">
            <span class="registry-key">FOLLOW</span>: <span class="registry-value">ONE ESSAY AT A TIME</span>
          </div>
          <h2>Follow the AI Agent Lifecycle column.</h2>
          <p>New essays are published when the argument is ready, starting with the origin essay and continuing with the four-layer definition.</p>
        </div>
        <a href="/newsletter/" class="lifecycle-button">Open newsletter</a>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .lifecycle-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.2rem;
    margin-top: 1.4rem;
  }

  .lifecycle-hero-link {
    text-decoration: none;
  }

  .lifecycle-hero-link:hover .registry-value {
    color: var(--accent-signal);
  }

  .lifecycle-shell {
    display: grid;
    gap: 4rem;
  }

  .lifecycle-opening,
  .lifecycle-concepts,
  .newsletter-cta,
  .first-essay-panel {
    padding: 2.25rem;
  }

  .lifecycle-concepts {
    border-left: 2px solid var(--accent-proof);
  }

  .lifecycle-opening--main {
    border-left: 3px solid var(--accent-signal);
  }

  .first-essay-panel {
    display: grid;
    grid-template-columns: minmax(260px, 0.72fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
    border-left: 2px solid var(--accent-proof);
  }

  .first-essay-cover {
    display: block;
    border: 1px solid var(--current-line);
    background: #111111;
    text-decoration: none;
  }

  .first-essay-cover img {
    width: 100%;
    height: auto;
  }

  .first-essay-copy h2 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .first-essay-copy p {
    margin: 0;
    color: var(--current-muted);
    font-size: 1rem;
    line-height: 1.66;
  }

  .first-essay-copy .first-essay-note {
    margin-top: 0.9rem;
    color: var(--current-text);
  }

  .lifecycle-text-link {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--accent-signal);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .lifecycle-text-link:hover {
    color: var(--current-text);
  }

  .concept-link-stack {
    display: flex;
    flex-wrap: wrap;
    align-content: start;
    gap: 0.8rem 1rem;
  }

  .start-link-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1rem;
  }

  .concept-link-stack .lifecycle-text-link {
    margin-top: 0;
  }

  .opening-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 3rem;
  }

  .opening-grid h2,
  .section-header h2,
  .newsletter-cta h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .opening-grid p,
  .section-desc,
  .newsletter-cta p {
    margin: 0;
    color: var(--current-muted);
    font-size: 1rem;
    line-height: 1.68;
  }

  .opening-notes {
    display: grid;
    gap: 1rem;
  }

  .opening-notes p:first-child {
    color: var(--current-text);
  }

  .lifecycle-section {
    display: grid;
    gap: 1.5rem;
  }

  .section-header {
    max-width: 68rem;
  }

  .lifecycle-card-grid,
  .relationship-grid,
  .failure-grid,
  .proof-route-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .lifecycle-card {
    padding: 1.4rem;
  }

  .lifecycle-card h3,
  .next-essay-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--current-text);
  }

  .lifecycle-card p {
    margin: 0;
    color: var(--current-muted);
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .lifecycle-card--relation {
    border-top: 2px solid var(--accent-proof);
  }

  .relation-role {
    display: block;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-signal);
  }

  .failure-card,
  .proof-route-card {
    display: grid;
    align-content: start;
    gap: 0.65rem;
    padding: 1.4rem;
    color: var(--current-text);
    text-decoration: none;
  }

  .failure-card:hover h3,
  .proof-route-card:hover h3 {
    color: var(--accent-signal);
  }

  .failure-card h3,
  .proof-route-card h3 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .failure-card p,
  .proof-route-card p {
    margin: 0;
    color: var(--current-muted);
    font-size: 0.9rem;
    line-height: 1.58;
  }

  .proof-route-card span {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-proof);
  }

  .prelude-list {
    display: grid;
    border: 1px solid var(--current-line);
  }

  .prelude-link {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    padding: 1.15rem 1.25rem;
    color: var(--current-text);
    text-decoration: none;
    border-bottom: 1px solid var(--current-line);
  }

  .prelude-link:last-child {
    border-bottom: none;
  }

  .prelude-link:hover strong {
    color: var(--accent-signal);
  }

  .prelude-index {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    color: var(--accent-proof);
    letter-spacing: 0.06em;
  }

  .prelude-copy {
    display: grid;
    gap: 0.35rem;
  }

  .prelude-copy strong {
    font-size: 1rem;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .prelude-copy span {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--current-muted);
  }

  .next-essay-card {
    padding: 1.5rem;
    border-left: 2px solid var(--accent-proof);
  }

  .newsletter-cta {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: center;
  }

  .lifecycle-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1.1rem;
    background: var(--accent-signal);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
  }

  .lifecycle-button:hover {
    opacity: 0.88;
  }

  @media (max-width: 980px) {
    .opening-grid,
    .newsletter-cta,
    .first-essay-panel {
      grid-template-columns: 1fr;
    }

    .lifecycle-card-grid,
    .relationship-grid,
    .failure-grid,
    .proof-route-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .newsletter-cta {
      display: grid;
      align-items: start;
    }
  }

  @media (max-width: 640px) {
    .lifecycle-shell {
      gap: 2.5rem;
    }

    .lifecycle-opening,
    .lifecycle-concepts,
    .newsletter-cta,
    .first-essay-panel {
      padding: 1.5rem;
    }

    .opening-grid {
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }

    .lifecycle-card-grid,
    .relationship-grid,
    .failure-grid,
    .proof-route-grid {
      grid-template-columns: 1fr;
    }

    .prelude-link {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding: 1rem;
    }
  }
</style>
