---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import {
  getProjectBySlug,
  lifecyclePageContent,
  pageRegistry,
  siteConfig,
  siteSemanticBaseline
} from "../data/site";

const canonicalPath = "/lifecycle/";
const lifecycleUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const proofPathProjects = ["cognitive-os", "solocrew", "validation-lab"]
  .map((projectSlug) => getProjectBySlug(projectSlug))
  .filter((project): project is NonNullable<ReturnType<typeof getProjectBySlug>> => Boolean(project));
const definitionExclusions = [
  "deployment lifecycle",
  "runtime state lifecycle",
  "manifest lifecycle",
  "workflow lifecycle"
];
const conceptChain = [
  "AI Agent Lifecycle",
  "Agentic Delivery",
  "MPLP",
  "Confirmation Boundary",
  "Evidence Chain",
  "Semantic Loss",
  "Cognitive OS",
  "SoloCrew",
  "Validation Lab"
];
const lifecycleJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteConfig.siteUrl}/lifecycle/#webpage`,
  url: lifecycleUrl,
  name: "The AI Agent Lifecycle",
  headline: "The AI Agent Lifecycle",
  description: siteSemanticBaseline.fieldDefinitionStatement,
  author: {
    "@id": `${siteConfig.siteUrl}#person`
  },
  mainEntity: {
    "@type": "DefinedTerm",
    name: "AI Agent Lifecycle",
    description: siteSemanticBaseline.fieldDefinitionStatement,
    inDefinedTermSet: {
      "@type": "DefinedTermSet",
      name: "JearonWong.com AI Agent Lifecycle concept architecture"
    },
    about: conceptChain
  },
  about: [
    "AI Agent Lifecycle",
    "Agentic Delivery",
    "Multi-Agent Lifecycle Governance",
    "MPLP",
    "Confirmation Boundary",
    "Evidence Chain",
    "Semantic Loss",
    "accountable outcomes",
    "lifecycle protocol",
    "accountable delivery"
  ]
};
---

<BaseLayout
  title={pageRegistry.lifecycle.title}
  description={siteSemanticBaseline.fieldDefinitionStatement}
  canonicalPath={canonicalPath}
  shareTitle="The AI Agent Lifecycle — A Field Definition by Jearon Wong"
  shareDescription={`${siteSemanticBaseline.fieldDefinitionStatement} ${siteSemanticBaseline.agenticDeliveryDefinition}`}
  ogImagePath="/social/jearonwong-og.png"
  ogImageAlt="The AI Agent Lifecycle — A field definition by Jearon Wong"
  jsonLd={[lifecycleJsonLd]}
>
  <RegistryPageHero
    title={lifecyclePageContent.hero.title}
    subtitle={lifecyclePageContent.hero.subtitle}
    objectType={pageRegistry.lifecycle.objectType}
    objectValue={pageRegistry.lifecycle.objectValue}
    leadLines={lifecyclePageContent.hero.leadLines}
    class="lifecycle-judgment-hero"
  >
    <div class="lifecycle-hero-links" aria-label="Lifecycle route links">
      <a href="/projects/mplp/" class="registry-annotation lifecycle-hero-link">
        <span class="registry-key">PROTOCOL_PATH</span>: <span class="registry-value">MPLP</span>
      </a>
      <a href="/projects/" class="registry-annotation lifecycle-hero-link">
        <span class="registry-key">PROOF_PATH</span>: <span class="registry-value">COGNITIVE OS / SOLOCREW / VALIDATION LAB</span>
      </a>
      <a href="/essays/" class="registry-annotation lifecycle-hero-link">
        <span class="registry-key">PUBLIC_ARGUMENTS</span>: <span class="registry-value">ESSAYS</span>
      </a>
    </div>
  </RegistryPageHero>

  <div class="zone-b page-body lifecycle-body">
    <div class="shell lifecycle-shell">
      <section class="registry-chassis lifecycle-thesis-band">
        <div class="registry-annotation lifecycle-section-tag">
          <span class="registry-key">01_THE_THESIS</span>
        </div>
        <h2>{lifecyclePageContent.thesis.title}</h2>
        <p>{lifecyclePageContent.thesis.body}</p>
      </section>

      <section class="registry-chassis definition-band">
        <div class="definition-band__header">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">02_FIELD_DEFINITION</span>
          </div>
          <h2>{lifecyclePageContent.fieldDefinition.title}</h2>
        </div>
        <div class="definition-band__copy">
          <p>{lifecyclePageContent.fieldDefinition.body[0]}</p>
          <div class="not-merely-ledger" aria-label="What AI Agent Lifecycle is not merely">
            <p>It is not merely:</p>
            <div>
              {definitionExclusions.map((item) => (
                <span>{item}</span>
              ))}
            </div>
          </div>
          <p>{lifecyclePageContent.fieldDefinition.body[2]}</p>
          <p class="sharp-line">A manifest can describe an agent. It cannot govern agent work.</p>
        </div>
      </section>

      <section class="registry-chassis dynamic-reality-band">
        <div class="registry-annotation lifecycle-section-tag">
          <span class="registry-key">03_DYNAMIC_AGENT_REALITY</span>
        </div>
        <div class="dynamic-reality-grid">
          <div>
            <h2>{lifecyclePageContent.dynamicReality.title}</h2>
            <p class="dynamic-lead">{lifecyclePageContent.dynamicReality.body[0]}</p>
            <p class="dynamic-lead">{lifecyclePageContent.dynamicReality.body[1]}</p>
          </div>
          <div class="market-ledger">
            {lifecyclePageContent.dynamicReality.body.slice(2).map((line) => (
              <p>{line}</p>
            ))}
          </div>
        </div>
      </section>

      <section class="lifecycle-split-section">
        <article class="registry-chassis ledger-panel">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">04_CATEGORY</span>
          </div>
          <h2>{lifecyclePageContent.category.title}</h2>
          {lifecyclePageContent.category.body.map((line) => (
            <p>{line}</p>
          ))}
        </article>

        <article class="registry-chassis ledger-panel ledger-panel--scope">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">05_GOVERNANCE_SCOPE</span>
          </div>
          <h2>{lifecyclePageContent.governanceScope.title}</h2>
          {lifecyclePageContent.governanceScope.body.map((line) => (
            <p>{line}</p>
          ))}
        </article>
      </section>

      <section class="governance-primitives">
        <div class="section-header">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">06_GOVERNANCE_PRIMITIVES</span>
          </div>
          <h2>Governance primitives</h2>
        </div>
        <div class="primitive-ledger">
          {lifecyclePageContent.governancePrimitives.map((primitive, index) => (
            <article class="primitive-row">
              <span class="primitive-index">{String(index + 1).padStart(2, "0")}</span>
              <h3>{primitive.name}</h3>
              <p>{primitive.definition}</p>
            </article>
          ))}
        </div>
        <div class="registry-chassis pairing-band">
          {lifecyclePageContent.governancePairing.map((line) => (
            <p>{line}</p>
          ))}
        </div>
      </section>

      <section class="lifecycle-split-section">
        <article class="registry-chassis ledger-panel ledger-panel--protocol">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">07_PROTOCOL_PATH</span>
          </div>
          <h2>{lifecyclePageContent.protocolPath.title}</h2>
          <p>{lifecyclePageContent.protocolPath.body}</p>
          <p>{lifecyclePageContent.protocolPath.boundary}</p>
        </article>

        <article class="registry-chassis ledger-panel ledger-panel--runtime">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">08_RUNTIME_SUBSTRATE_NOTE</span>
          </div>
          <h2>{lifecyclePageContent.runtimeSubstrate.title}</h2>
          <p>{lifecyclePageContent.runtimeSubstrate.body}</p>
          <p>Forthcoming technical depth. Not the first public surface.</p>
        </article>
      </section>

      <section class="proof-path-section">
        <div class="section-header">
          <div class="registry-annotation lifecycle-section-tag">
            <span class="registry-key">09_PROOF_PATH</span>
          </div>
          <h2>{lifecyclePageContent.proofPath.title}</h2>
          <p>{lifecyclePageContent.proofPath.body}</p>
        </div>
        <div class="proof-path-grid">
          {proofPathProjects.map((project) => (
            <ProjectProofCard
              {...project}
              href={`/projects/${project.slug}/`}
              linkLabel="Open proof path record"
              compact
            />
          ))}
        </div>
      </section>

      <section class="registry-chassis closing-anchor">
        <div class="registry-annotation lifecycle-section-tag">
          <span class="registry-key">10_CLOSING_ANCHOR</span>
        </div>
        <p>{lifecyclePageContent.closingAnchor}</p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .lifecycle-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.15rem;
    margin-top: 1.7rem;
  }

  .lifecycle-hero-link {
    text-decoration: none;
  }

  .lifecycle-hero-link:hover .registry-value {
    color: var(--accent-signal);
  }

  .lifecycle-body {
    padding: 6rem 0;
  }

  .lifecycle-shell {
    display: grid;
    gap: 3rem;
  }

  .lifecycle-section-tag {
    margin-bottom: 1rem;
  }

  .lifecycle-thesis-band,
  .definition-band,
  .dynamic-reality-band,
  .ledger-panel,
  .pairing-band,
  .closing-anchor {
    padding: 2.25rem;
  }

  .lifecycle-thesis-band {
    border-left: 4px solid var(--accent-signal);
    background: #111111;
    color: #f1f5f9;
    --current-surface: #111111;
    --current-border: rgba(255, 255, 255, 0.1);
    --current-line: rgba(255, 255, 255, 0.08);
    --current-muted: rgba(226, 232, 240, 0.68);
    --current-text: #f1f5f9;
  }

  .lifecycle-thesis-band h2,
  .definition-band h2,
  .dynamic-reality-band h2,
  .ledger-panel h2,
  .section-header h2 {
    margin: 0;
    color: var(--current-text);
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
  }

  .lifecycle-thesis-band p {
    max-width: 55rem;
    margin: 1.1rem 0 0;
    color: var(--current-muted);
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    line-height: 1.6;
  }

  .definition-band {
    display: grid;
    grid-template-columns: minmax(0, 0.42fr) minmax(0, 0.58fr);
    gap: 3rem;
    border-top: 2px solid var(--accent-proof);
  }

  .definition-band__copy {
    display: grid;
    gap: 1.1rem;
  }

  .definition-band__copy p,
  .dynamic-reality-band p,
  .ledger-panel p,
  .section-header p,
  .closing-anchor p {
    margin: 0;
    color: var(--current-muted);
    font-size: 1rem;
    line-height: 1.68;
  }

  .definition-band__copy p:first-child,
  .ledger-panel p:first-of-type,
  .dynamic-lead,
  .closing-anchor p {
    color: var(--current-text);
  }

  .sharp-line {
    padding-left: 1rem;
    border-left: 3px solid var(--accent-signal);
    font-weight: 760;
  }

  .not-merely-ledger {
    display: grid;
    gap: 0.8rem;
    padding: 1rem 0;
    border-top: 1px solid var(--current-line);
    border-bottom: 1px solid var(--current-line);
  }

  .not-merely-ledger p {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-signal);
  }

  .not-merely-ledger div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .not-merely-ledger span {
    padding: 0.45rem 0.62rem;
    border: 1px solid var(--current-border);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--current-text);
  }

  .dynamic-reality-band {
    border-left: 3px solid var(--accent-signal);
  }

  .dynamic-reality-grid,
  .lifecycle-split-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .dynamic-reality-grid {
    gap: 3rem;
  }

  .dynamic-lead {
    margin-top: 1.1rem !important;
    font-size: clamp(1.1rem, 2vw, 1.38rem) !important;
    line-height: 1.46 !important;
    font-weight: 780;
  }

  .market-ledger {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding-top: 0.2rem;
  }

  .market-ledger p {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--current-line);
  }

  .market-ledger p:last-child {
    padding-bottom: 0;
    border-bottom: none;
    color: var(--current-text);
    font-weight: 760;
  }

  .ledger-panel {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .ledger-panel--scope,
  .ledger-panel--protocol {
    border-top: 2px solid var(--accent-proof);
  }

  .ledger-panel--runtime {
    border-top: 2px solid var(--accent-caution);
  }

  .governance-primitives,
  .proof-path-section {
    display: grid;
    gap: 1.35rem;
  }

  .section-header {
    max-width: 68rem;
  }

  .primitive-ledger {
    border: 1px solid var(--current-border);
    background: var(--current-surface);
  }

  .primitive-row {
    display: grid;
    grid-template-columns: 4.5rem minmax(12rem, 0.35fr) minmax(0, 1fr);
    gap: 1.2rem;
    align-items: start;
    padding: 1.35rem 1.5rem;
    border-bottom: 1px solid var(--current-line);
  }

  .primitive-row:last-child {
    border-bottom: none;
  }

  .primitive-index {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--accent-proof);
    letter-spacing: 0.08em;
  }

  .primitive-row h3 {
    margin: 0;
    color: var(--current-text);
    font-size: 1.05rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .primitive-row p {
    margin: 0;
    color: var(--current-muted);
    font-size: 0.98rem;
    line-height: 1.62;
  }

  .pairing-band {
    display: grid;
    gap: 0.35rem;
    border-left: 3px solid var(--accent-proof);
  }

  .pairing-band p {
    margin: 0;
    color: var(--current-text);
    font-size: clamp(1.12rem, 2vw, 1.5rem);
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .proof-path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .closing-anchor {
    border-left: 4px solid var(--accent-signal);
  }

  .closing-anchor p {
    max-width: 58rem;
    font-size: clamp(1.3rem, 3vw, 2rem);
    line-height: 1.22;
    font-weight: 840;
    letter-spacing: -0.02em;
  }

  @media (max-width: 980px) {
    .definition-band,
    .dynamic-reality-grid,
    .lifecycle-split-section,
    .proof-path-grid {
      grid-template-columns: 1fr;
    }

    .primitive-row {
      grid-template-columns: 3.5rem minmax(0, 1fr);
    }

    .primitive-row p {
      grid-column: 2;
    }
  }

  @media (max-width: 640px) {
    .lifecycle-body {
      padding: 4rem 0;
    }

    .lifecycle-shell {
      gap: 2.25rem;
    }

    .lifecycle-thesis-band,
    .definition-band,
    .dynamic-reality-band,
    .ledger-panel,
    .pairing-band,
    .closing-anchor {
      padding: 1.4rem;
    }

    .primitive-row {
      grid-template-columns: 1fr;
      gap: 0.55rem;
      padding: 1.15rem;
    }

    .primitive-row p {
      grid-column: auto;
    }
  }
</style>
