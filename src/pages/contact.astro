---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { pageRegistry, socialLinks, siteConfig } from "../data/site";
---

<BaseLayout title="Contact" description={pageRegistry.contact.lead}>
  <RegistryPageHero
    title={pageRegistry.contact.title}
    objectType={pageRegistry.contact.objectType}
    objectValue={pageRegistry.contact.objectValue}
    lead={pageRegistry.contact.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell shell--narrow page-stack page-stack--tight">

      <!-- Primary: Email -->
      <article class="registry-chassis contact-block">
        <div class="registry-annotation" style="margin-bottom: 1.25rem;">
          <span class="registry-key">PRIMARY_CHANNEL</span>
        </div>
        <a href={`mailto:${siteConfig.author.email}`} class="email-cta">
          {siteConfig.author.email}
        </a>
        <p class="contact-note">For direct conversations about Protocol Engineering, agent governance, proof systems, or collaboration.</p>
      </article>

      <!-- Social channels -->
      <article class="registry-chassis contact-block">
        <div class="registry-annotation" style="margin-bottom: 1.25rem;">
          <span class="registry-key">SOCIAL_CHANNELS</span>
        </div>
        <div class="channel-grid">
          {socialLinks.map(link => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="channel-row">
              <span class="channel-key">{link.platform.toUpperCase()}</span>
              <span class="channel-value">{link.label}</span>
            </a>
          ))}
        </div>
      </article>

    </section>
  </div>
</BaseLayout>

<style>
  .contact-block {
    padding: var(--registry-panel-padding);
  }
  .email-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--accent-signal);
    text-decoration: none;
    letter-spacing: 0.02em;
    padding: 0.8rem 1.5rem;
    border: 1px solid var(--accent-signal);
    border-radius: 2px;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .email-cta:hover {
    background: var(--accent-signal);
    color: white;
  }
  .contact-note {
    margin: 1.5rem 0 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--current-muted);
    max-width: 55ch;
  }
  .channel-grid {
    display: grid;
    gap: 0;
  }
  .channel-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--current-line);
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .channel-row:first-child {
    border-top: 1px solid var(--current-line);
  }
  .channel-row:hover {
    background: rgba(59, 130, 246, 0.03);
  }
  .channel-key {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-signal);
  }
  .channel-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--current-muted);
  }
  @media (max-width: 768px) {
    .contact-block {
      padding: var(--registry-card-padding);
    }
    .email-cta {
      font-size: 0.95rem;
      padding: 0.65rem 1.1rem;
    }
    .channel-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding: 0.7rem 0;
    }
  }
</style>
