---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import { theoryClusters, siteConfig } from "../data/site";
---

<BaseLayout title={`Ideas | ${siteConfig.title}`}>
  <div class="zone-a genesis-stage" style="padding-top: 8rem; padding-bottom: 6rem;">
    <SiteHeader />
    <div class="shell">
      <h1 class="text-gradient">Conceptual Blueprint</h1>
      <p class="lead" style="max-width: 50ch;">The core framework for autonomous agent work delivery. Three pillars of protocol engineering.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="card-grid">
        {theoryClusters.map(cluster => (
          <SignatureIdeaCard {...cluster} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 3rem;
  }
  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
