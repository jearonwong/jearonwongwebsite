---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
---

<BaseLayout
  title="Ideas"
  description="Compatibility route retained for older links. The canonical ideas route is /theories."
  canonicalPath="/theories"
  noindex={true}
>
  <RegistryPageHero
    title="IDEAS_ROUTE_REDIRECT"
    objectType="OBJECT_TYPE"
    objectValue="LEGACY_COMPATIBILITY"
    lead="The canonical ideas route is now /theories. This compatibility page remains only so older links still have a clear destination."
  >
    <div class="registry-annotation">
      <span class="registry-key">NEXT_ROUTE</span>: <span class="registry-value">/theories/</span>
    </div>
  </RegistryPageHero>
</BaseLayout>
