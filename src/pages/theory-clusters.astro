---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { pageRegistry } from "../data/site";
---

<BaseLayout
  title="Ideas"
  description="Compatibility route retained for older links. The canonical ideas route is /theories."
  canonicalPath="/theories/"
  noindex={true}
>
  <RegistryPageHero
    title={pageRegistry.ideasLegacy.title}
    objectType={pageRegistry.ideasLegacy.objectType}
    objectValue={pageRegistry.ideasLegacy.objectValue}
    lead={pageRegistry.ideasLegacy.lead}
  >
    <div class="registry-annotation">
      <span class="registry-key">NEXT_ROUTE</span>: <span class="registry-value">/theories/</span>
    </div>
    <div style="margin-top: 1.5rem;">
      <a href="/theories/" class="button button-outline">Open Ideas</a>
    </div>
  </RegistryPageHero>
</BaseLayout>
