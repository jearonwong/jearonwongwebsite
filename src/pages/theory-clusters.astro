---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import { theoryClusters, siteConfig } from "../data/site";
---

<BaseLayout title={`Blueprint | ${siteConfig.title}`}>
  <div class="zone-a registry-grid" style="padding-top: 10rem; padding-bottom: 6rem; border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    <div class="shell">
      <div class="registry-annotation" style="margin-bottom: 1rem;">
        <span class="registry-key">OBJECT_TYPE</span>: <span class="registry-value">CONCEPTUAL_BLUEPRINT</span>
      </div>
      <h1 style="font-size: 4rem; font-weight: 800; letter-spacing: -0.04em;">SYSTEM PILLARS</h1>
      <p class="lead" style="max-width: 50ch;">The core framework for autonomous agent work delivery. Structured as three auditable system modules.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="spec-stack">
        {theoryClusters.map(cluster => (
          <div class="spec-panel-wrapper">
            <SignatureIdeaCard {...cluster} />
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .spec-stack {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .spec-panel-wrapper {
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 4rem;
  }
  .spec-panel-wrapper:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
</style>
