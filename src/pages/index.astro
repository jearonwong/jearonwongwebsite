---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PortraitAnchor from "../components/PortraitAnchor.astro";
import ImmediateProofSignal from "../components/ImmediateProofSignal.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import CoreArchitectureMap from "../components/CoreArchitectureMap.astro";
import { homepageActions, homepageContent, siteConfig, projects, socialLinks } from "../data/site";

const allEssays = (await getCollection("essays"))
  .sort((left, right) =>
    Number(right.data.flagship) - Number(left.data.flagship) ||
    right.data.publishDate.getTime() - left.data.publishDate.getTime()
  );

const essaysBySlug = new Map(allEssays.map((essay) => [essay.slug, essay]));
const readingPathEntries = homepageContent.readingPath
  .map((entry, index) => {
    const essay = essaysBySlug.get(entry.slug);
    return essay ? { ...entry, essay, index } : null;
  })
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));

const agenticDeliveryFlowRows = [
  homepageContent.coreThesis.agenticDeliveryFlow.slice(0, 4),
  homepageContent.coreThesis.agenticDeliveryFlow.slice(4)
];

const writingTracks = [
  { name: "Protocol Engineering", desc: "Lifecycle vocabulary, handoff semantics, and delivery grammar for agent systems." },
  { name: "Reliable Agent Delivery", desc: "How agent systems complete real work — plannable, verifiable, and auditable." },
  { name: "Agent Governance & Evidence", desc: "Oversight structures, compliance surfaces, and accountability frameworks for autonomous work." },
  { name: "AI Programming & Delivery Systems", desc: "Runtime architecture, state management, and operating constraints for protocol-aware agents." },
  { name: "Agent Stack Commentary", desc: "Analysis and perspective on the evolving agent infrastructure landscape." }
];
---

<BaseLayout
  title={siteConfig.title}
  description={siteConfig.description}
  shareTitle="Who Governs the Lifecycle?"
  shareDescription="AI agents are learning to act, but reliable delivery still needs lifecycle accountability. Jearon Wong writes and builds around Agentic Delivery."
  ogImagePath="/social/jearonwong-og.png"
  ogImageAlt="Who governs the lifecycle? AI agents can act. Reliable delivery still needs accountability."
>
  <!-- 1. Problem + Concept + Author Anchor (Hero) -->
  <div class="zone-a registry-grid hero-wrapper" style="border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    
    <section class="shell hero-section">
      <div class="split-layout">
        <div class="hero-content">
          <div class="hero-technical-hook registry-annotation">
            {homepageContent.hero.technicalHookLines.map((line) => (
              <span>{line}</span>
            ))}
          </div>
          <h1 class="hero-nameplate">
            {homepageContent.hero.hookLines.map((line) => (
              <span>{line}</span>
            ))}
          </h1>
          <p class="hero-thesis">{homepageContent.hero.concept}</p>
          <div class="hero-author-anchor">
            <span class="hero-author-name">{homepageContent.hero.authorAnchor}</span>
            <span class="hero-role-line">{homepageContent.hero.role}</span>
          </div>
          <p class="hero-support">{homepageContent.hero.support}</p>
          
          <div class="hero-ctas">
            <a href={homepageActions.thesis.href} class="button button-primary">{homepageActions.thesis.label}</a>
            <a href={homepageActions.projects.href} class="button button-outline" style="border: 1px solid var(--border-registry); background: rgba(255,255,255,0.05);">{homepageActions.projects.label}</a>
          </div>

          <div class="proof-signal-band">
            <ImmediateProofSignal />
          </div>
        </div>
        <div class="hero-visual">
          <PortraitAnchor />
        </div>
      </div>
    </section>
  </div>

  <!-- 2. Stack Architecture -->
  <div class="zone-b page-body page-body--stack">
    <CoreArchitectureMap />
  </div>

  <!-- 3. Core Thesis -->
  <section class="zone-a registry-grid core-thesis-band">
    <div class="shell core-thesis-layout">
      <div class="core-thesis-copy">
        <div class="registry-annotation core-thesis-eyebrow">
          <span class="registry-key">{homepageContent.coreThesis.eyebrow}</span>
        </div>
        <h2>{homepageContent.coreThesis.title}</h2>
        <p><strong>Most agent systems optimize execution:</strong> {homepageContent.coreThesis.execution.replace("Most agent systems optimize execution: ", "")}</p>
        <p><strong>My work starts from delivery:</strong> {homepageContent.coreThesis.delivery.replace("My work starts from delivery: ", "")}</p>
      </div>

      <div class="thesis-compare registry-chassis" aria-label="Task execution versus Agentic Delivery">
        <div class="compare-track">
          <span class="compare-label">{homepageContent.coreThesis.taskAgentLabel}</span>
          <div class="compare-flow">
            {homepageContent.coreThesis.taskAgentFlow.map((step, index) => (
              <>
                <span class="compare-step">{step}</span>
                {index < homepageContent.coreThesis.taskAgentFlow.length - 1 && <span class="compare-arrow" aria-hidden="true">-&gt;</span>}
              </>
            ))}
          </div>
        </div>

        <div class="compare-track compare-track--delivery">
          <span class="compare-label">{homepageContent.coreThesis.agenticDeliveryLabel}</span>
          <div class="compare-flow compare-flow--delivery">
            {agenticDeliveryFlowRows.map((row, rowIndex) => (
              <div class:list={["compare-flow-row", rowIndex > 0 && "compare-flow-row--continuation"]}>
                {row.map((step, index) => (
                  <>
                    <span class="compare-step">{step}</span>
                    {index < row.length - 1 && <span class="compare-arrow" aria-hidden="true">-&gt;</span>}
                  </>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="zone-b page-body">
    <!-- 4. Proof Surfaces -->
    <section id="proof" class="shell section-rhythm">
      <div class="section-header">
        <h2>Proof Surfaces</h2>
        <p class="section-desc">Each surface proves one layer of the Agentic Delivery stack.</p>
        <a href={homepageActions.proof.href} class="section-link">{homepageActions.proof.label}</a>
      </div>
      <div class="card-grid">
        {projects.map(project => (
          <ProjectProofCard
            {...project}
            href={`/projects/${project.slug}/`}
            compact
          />
        ))}
      </div>
    </section>

    <!-- 5. Reading Path -->
    {readingPathEntries.length > 0 && (
      <section class="shell section-rhythm" style="padding-top: 2rem;">
        <div class="section-header">
          <h2>Reading Path</h2>
          <p class="section-desc">Start with the public arguments that define the Agentic Delivery stack.</p>
        </div>
        <div class="reading-path-list">
          {readingPathEntries.map((entry) => (
            <article class="reading-path-card">
              <span class="reading-path-index">{String(entry.index + 1).padStart(2, "0")}</span>
              <div class="reading-path-content">
                <h3><a href={`/essays/${entry.essay.slug}/`}>{entry.essay.data.title}</a></h3>
                <p>{entry.note}</p>
                <a href={`/essays/${entry.essay.slug}/`} class="section-link">Read essay</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- 6. Writing Tracks -->
    <section class="shell section-rhythm" style="padding-top: 2rem;">
      <div class="section-header">
        <h2>Writing tracks.</h2>
        <p class="section-desc">Five lines of inquiry across protocols, governance, runtime, delivery, and product.</p>
        <a href={homepageActions.essays.href} class="section-link">{homepageActions.essays.label}</a>
      </div>
      <div class="tracks-grid">
        {writingTracks.map(track => (
          <div class="track-item">
            <h4 class="track-name">{track.name}</h4>
            <p class="track-desc">{track.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 7. Contact / Signal -->
    <section class="shell section-rhythm quiet-close" style="padding-top: 2rem;">
      <div class="close-content">
        <h2>Get in touch.</h2>
        <p class="section-desc">For industry dialogue, advisory, collaboration, or media.</p>
        <div class="close-actions">
          <a href={`mailto:${siteConfig.author.email}`} class="button button-primary" style="background: #111; color: #fff;">{siteConfig.author.email}</a>
          <div class="close-social">
            {socialLinks.map(link => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="social-pill">{link.platform}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-wrapper {
    position: relative;
    overflow: hidden;
  }
  .hero-section {
    padding-top: 4.85rem;
    padding-bottom: 5.5rem;
  }
  .hero-technical-hook {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.3rem;
    color: var(--accent-signal);
  }
  .hero-nameplate {
    font-size: clamp(2.85rem, 5.6vw, 4.45rem);
    font-weight: 820;
    letter-spacing: -0.05em;
    line-height: 0.98;
    margin: 0 0 1.65rem;
    color: var(--text-registry-primary);
    max-width: 18ch;
  }
  .hero-nameplate span {
    display: block;
  }
  .hero-thesis {
    font-size: clamp(1.18rem, 2.2vw, 1.55rem);
    font-weight: 650;
    letter-spacing: -0.01em;
    line-height: 1.38;
    margin: 0 0 1.65rem;
    color: var(--text-registry-muted);
    max-width: 54ch;
  }
  .hero-author-anchor {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.85rem;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  .hero-author-name {
    font-weight: 800;
    color: var(--text-registry-primary);
    letter-spacing: -0.01em;
  }
  .hero-role-line {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-registry-muted);
    font-weight: 600;
    line-height: 1.55;
  }
  .hero-support {
    max-width: 58ch;
    color: var(--text-registry-muted);
    font-size: 1.05rem;
    line-height: 1.65;
    font-weight: 400;
    margin-bottom: 2.25rem;
  }
  .proof-signal-band {
    margin-top: 2.25rem;
    padding: 1.25rem 1.5rem;
    background-color: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-registry);
    border-left: 3px solid var(--accent-signal);
    max-width: 34rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  /* ── Sections ── */
  .section-header h2 {
    font-size: clamp(1.8rem, 3.2vw, 2.35rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin-bottom: 0.6rem;
  }
  .section-desc {
    font-size: 1rem;
    color: var(--current-muted);
    line-height: 1.6;
    max-width: min(100%, 58rem);
    margin-bottom: 0.25rem;
  }
  .section-link {
    display: inline-flex;
    align-items: center;
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .section-link:hover {
    color: var(--current-text);
  }
  .section-header {
    margin-bottom: 3.5rem;
  }

  /* ── Core Thesis ── */
  .core-thesis-band {
    padding: 6rem 0;
    border-top: 1px solid var(--border-registry);
    border-bottom: 1px solid var(--border-registry);
  }

  .core-thesis-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 4rem;
    align-items: center;
  }

  .core-thesis-eyebrow {
    margin-bottom: 1rem;
  }

  .core-thesis-copy h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.35rem;
    font-weight: 800;
  }

  .core-thesis-copy p {
    max-width: 42rem;
    margin: 0;
    color: var(--text-registry-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .core-thesis-copy p + p {
    margin-top: 1rem;
  }

  .core-thesis-copy strong {
    color: var(--text-registry-primary);
  }

  .thesis-compare {
    padding: 1.65rem 1.85rem;
    background-color: rgba(10, 10, 10, 0.54);
  }

  .compare-track {
    display: grid;
    grid-template-columns: 9.5rem minmax(0, 1fr);
    gap: 1.25rem;
    align-items: start;
  }

  .compare-track + .compare-track {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-registry);
  }

  .compare-label {
    display: block;
    margin-top: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
  }

  .compare-track--delivery .compare-label {
    color: var(--accent-proof);
  }

  .compare-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    min-width: 0;
  }

  .compare-flow--delivery {
    display: grid;
    gap: 0.62rem;
  }

  .compare-flow-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .compare-flow-row--continuation {
    padding-left: 0;
  }

  .compare-step {
    padding: 0.42rem 0.62rem;
    border: 1px solid var(--border-registry);
    background: rgba(255, 255, 255, 0.035);
    color: var(--text-registry-primary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    white-space: nowrap;
    text-align: center;
  }

  .compare-arrow {
    color: var(--text-registry-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  /* ── Card Grid ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }
  .card-grid :global(.evidence-record) {
    height: 100%;
  }

  /* ── Reading Path ── */
  .reading-path-list {
    display: grid;
    gap: 1rem;
  }

  .reading-path-card {
    display: grid;
    grid-template-columns: 4.5rem minmax(0, 1fr);
    gap: 1.25rem;
    background: var(--current-surface);
    border: 1px solid var(--current-border);
    border-left: 4px solid var(--accent-signal);
    border-radius: var(--radius-module);
    padding: 1.6rem 1.75rem;
  }

  .reading-path-index {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--accent-signal);
  }

  .reading-path-content h3 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    line-height: 1.18;
  }

  .reading-path-content h3 a {
    color: inherit;
    text-decoration: none;
  }

  .reading-path-content h3 a:hover {
    color: var(--accent-signal);
  }

  .reading-path-content p {
    color: var(--current-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0;
  }

  /* ── Writing Tracks ── */
  .tracks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0;
  }
  .track-item {
    padding: 1.5rem 1.5rem 1.5rem 0;
    border-bottom: 1px solid var(--current-line);
  }
  .track-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent-signal);
    margin-bottom: 0.5rem;
  }
  .track-desc {
    font-size: 0.9rem;
    color: var(--current-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Quiet Close ── */
  .quiet-close {
    padding-bottom: 2rem;
  }
  .close-content h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .close-actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  .close-social {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .social-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--current-muted);
    border: 1px solid var(--current-border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .social-pill:hover {
    border-color: var(--accent-signal);
    color: var(--accent-signal);
  }

  /* ── Layout ── */
  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
    gap: 5rem;
    align-items: start;
  }
  .hero-visual {
    justify-self: end;
    width: min(100%, 22rem);
    padding-top: 1.4rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .split-layout {
      gap: 3rem;
      grid-template-columns: 1fr;
    }
    .hero-visual {
      justify-self: start;
      width: min(100%, 21rem);
      padding-top: 0;
    }
  }

  @media (max-width: 980px) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }

  @media (max-width: 900px) {
    .split-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .hero-section {
      padding-top: 4rem;
      padding-bottom: 4.5rem;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 4.5rem;
      padding-bottom: 4rem;
    }
    .hero-nameplate {
      font-size: clamp(2.35rem, 9vw, 3.6rem);
    }
    .hero-thesis {
      font-size: clamp(1.08rem, 4.8vw, 1.35rem);
    }
    .hero-role-line {
      max-width: 28ch;
    }
    .hero-support {
      font-size: 0.95rem;
      max-width: 36ch;
    }
    .proof-signal-band {
      margin-top: 2rem;
      padding: 1.1rem 1.25rem;
    }
    .hero-visual {
      width: min(100%, 18rem);
    }
    .section-header {
      margin-bottom: 2.5rem;
    }
    .core-thesis-band {
      padding: 4.5rem 0;
    }
    .core-thesis-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .thesis-compare {
      padding: 1.35rem;
    }
    .compare-track {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
    .compare-label {
      margin-top: 0;
      margin-bottom: 0;
    }
    .tracks-grid {
      grid-template-columns: 1fr;
    }
    .reading-path-card {
      padding: 1.75rem;
    }
  }

  @media (max-width: 620px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
    .compare-flow--delivery {
      gap: 0.5rem;
    }
    .compare-track--delivery .compare-flow-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
    }
    .compare-track--delivery .compare-arrow {
      display: none;
    }
    .compare-track--delivery .compare-step {
      width: 100%;
      min-height: 2rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .compare-flow-row--continuation .compare-step:last-child {
      grid-column: 1 / -1;
    }
    .reading-path-card {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
  }
</style>
