---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PortraitAnchor from "../components/PortraitAnchor.astro";
import ImmediateProofSignal from "../components/ImmediateProofSignal.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { homepageActions, siteConfig, theoryClusters, projects } from "../data/site";

const essays = (await getCollection("essays"))
  .sort((left, right) => right.data.publishDate.getTime() - left.data.publishDate.getTime())
  .slice(0, 3);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <!-- 1. The Architectural Stage -> Command Center -->
  <div class="zone-a registry-grid hero-wrapper" style="border-bottom: 1px solid var(--border-registry);">
    <SiteHeader />
    
    <section class="shell hero-section">
      <div class="split-layout">
        <div class="hero-content">
          <div class="registry-annotation hero-sequence">
            <span class="registry-key">INIT_SEQUENCE</span>: <span class="registry-value">PROTOCOL_ARCHITECT_CORE</span>
          </div>
          <h1 class="hero-nameplate">{siteConfig.author.name}</h1>
          <p class="hero-role">
            <span class="firstname">PROTOCOL ARCHITECT</span>
            <span class="surname">FOR THE AGENT ERA</span>
          </p>
          <div class="registry-annotation hero-proposition">
            <span class="registry-key">PROPOSITION</span>: <span class="registry-value">DEFINING_RELIABLE_WORK_DELIVERY</span>
          </div>
          
          <p class="lead hero-lead">{siteConfig.thesis}</p>
          
          <div class="hero-ctas">
            <a href={homepageActions.thesis.href} class="button button-primary">{homepageActions.thesis.label}</a>
            <a href={homepageActions.projects.href} class="button button-outline" style="border: 1px solid var(--border-registry); background: rgba(255,255,255,0.05);">{homepageActions.projects.label}</a>
          </div>

          <div class="registry-chassis proof-signal-band">
            <div class="registry-grid" style="position: absolute; inset: 0; opacity: 0.05;"></div>
            <div class="registry-annotation" style="margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.75rem;">
              <span class="proof-signal-dot"></span>
              <span class="registry-key">SYSTEM_PROOFS</span>: <span class="registry-value">ACTIVE_STREAM</span>
            </div>
            <ImmediateProofSignal />
          </div>
        </div>
        <div class="hero-visual">
          <PortraitAnchor />
        </div>
      </div>
    </section>
  </div>

  <!-- 2. The Proposition -> Blueprint Zone -->
  <div class="zone-b page-body" style="padding-top: 6rem;">
    
    <section id="blueprint" class="shell section-rhythm">
      <div class="section-header" style="margin-bottom: 5rem; border-left: 4px solid var(--accent-signal); padding-left: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">MODULE</span>: <span class="registry-value">CONCEPTUAL_FRAMEWORK</span>
        </div>
        <h2 style="max-width: 20ch; font-weight: 800; letter-spacing: -0.03em;">Protocol architecture applied to autonomous agents.</h2>
        <a href={homepageActions.ideas.href} class="section-link">{homepageActions.ideas.label}</a>
      </div>
      <div class="card-grid">
        {theoryClusters.map(cluster => (
          <SignatureIdeaCard {...cluster} />
        ))}
      </div>
    </section>

    <!-- 3. The Narrative -> System State -->
    <section class="zone-a registry-grid narrative-band" style="padding: 8rem 0; margin: 6rem 0; border-top: 1px solid var(--border-registry); border-bottom: 1px solid var(--border-registry);">
      <div class="shell" style="max-width: 900px; text-align: left;">
        <div class="registry-annotation" style="margin-bottom: 2rem;">
          <span class="registry-key">SYSTEM_OBSERVATION</span>: <span class="registry-value">MARKET_GAP_ANALYSIS</span>
        </div>
        <h2 class="narrative-lead" style="font-size: 3rem; margin-bottom: 3rem;">
          The industry focused on models and tools. 
          <br/>The missing layer is <span style="color: var(--accent-proof);">reliable work delivery</span>.
        </h2>
        <div class="registry-chassis" style="padding: 2rem; border-left: 2px solid var(--accent-proof);">
          <p class="lead" style="margin: 0; color: var(--text-registry-muted);">
            Prompt Engineering controls expression. Context Engineering controls what models see. Protocol Engineering controls the evidence of delivery.
          </p>
        </div>
      </div>
    </section>

    <!-- 4. The Ledger -> Evidence Room -->
    <section id="ledger" class="shell section-rhythm">
      <div class="section-header" style="margin-bottom: 5rem; border-left: 4px solid var(--accent-proof); padding-left: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">MODULE</span>: <span class="registry-value">EVIDENCE_LEDGER</span>
        </div>
        <h2 style="font-weight: 800; letter-spacing: -0.02em;">Thinking made concrete.</h2>
        <a href={homepageActions.proof.href} class="section-link">{homepageActions.proof.label}</a>
      </div>
      <div class="card-grid">
        {projects.map(project => (
          <ProjectProofCard {...project} />
        ))}
      </div>
    </section>
    <!-- 5. Featured Writing -> Logbook Snippet -->
    <section class="shell section-rhythm" style="padding-top: 2rem;">
      <div class="section-header" style="margin-bottom: 5rem; border-left: 4px solid var(--current-line); padding-left: 2rem;">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">MODULE</span>: <span class="registry-value">REGISTRY_LOG_SUMMARY</span>
        </div>
        <h2 style="font-weight: 800; letter-spacing: -0.02em;">Arguments about governance, memory, and proof.</h2>
        <a href={homepageActions.essays.href} class="section-link">{homepageActions.essays.label}</a>
      </div>
      <div class="essay-list">
        {essays.map(essay => (
          <article class="essay-row">
            <span class="essay-date">{essay.data.publishDate.toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
            <div class="essay-content">
              <h3><a href={`/essays/${essay.slug}/`}>{essay.data.title}</a></h3>
              <p class="muted">{essay.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .hero-wrapper {
    position: relative;
    overflow: hidden;
  }
  .hero-section {
    padding-top: 5.25rem;
    padding-bottom: 7rem;
  }
  .hero-sequence {
    margin-bottom: 1.25rem;
  }
  .hero-nameplate {
    font-size: clamp(2.5rem, 5.4vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 0.94;
    margin-bottom: 1.1rem;
    color: var(--text-registry-primary);
    max-width: 10ch;
  }
  .hero-role {
    text-transform: uppercase;
    font-size: clamp(1.8rem, 3.9vw, 2.9rem);
    letter-spacing: -0.05em;
    line-height: 0.94;
    margin-bottom: 1.35rem;
    font-weight: 820;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    filter: drop-shadow(0 0 40px rgba(59, 130, 246, 0.04));
    max-width: 13ch;
    color: var(--current-text);
  }
  .hero-role span {
    display: block;
  }
  .hero-role .surname {
    color: inherit;
  }
  .hero-role .firstname {
    color: inherit;
  }
  .hero-proposition {
    margin-bottom: 1.85rem;
    color: var(--accent-signal);
    font-size: 0.78rem;
    font-weight: 700;
  }
  .hero-lead {
    max-width: 40ch; 
    color: var(--current-text); 
    opacity: 1;
    font-size: 1.14rem;
    line-height: 1.55;
    font-weight: 500;
    margin-bottom: 2.75rem;
    border-left: 2px solid var(--accent-signal);
    padding-left: 1.25rem;
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.03) 0%, transparent 100%);
  }
  .proof-signal-band {
    margin-top: 3.25rem; 
    padding: 1.7rem 1.8rem; 
    background-color: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    position: relative;
    border: 1px solid var(--border-registry);
    border-left: 3px solid var(--accent-signal);
    max-width: 37rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .section-header h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    margin-top: 1.15rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-signal);
    text-decoration: none;
  }

  .section-link:hover {
    color: var(--current-text);
  }

  .narrative-lead {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 1.5rem 0 2.5rem;
    font-weight: 800;
  }
  .narrative-lead em {
    font-style: italic;
    color: var(--zone-a-text);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
  }

  .essay-list {
    display: flex;
    flex-direction: column;
  }
  .essay-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    padding: 3rem 0;
    border-top: 1px solid var(--zone-b-line);
  }
  .essay-row:last-child {
    border-bottom: 1px solid var(--zone-b-line);
  }
  .essay-date {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--zone-b-muted);
    padding-top: 0.4rem;
  }
  .essay-content h3 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }
  
  .split-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
    gap: 5rem;
    align-items: start;
  }

  .hero-visual {
    justify-self: end;
    width: min(100%, 23rem);
    padding-top: 2rem;
  }

  @media (max-width: 1024px) {
    .split-layout {
      gap: 3rem;
      grid-template-columns: 1fr;
    }

    .hero-visual {
      justify-self: start;
      width: min(100%, 21rem);
      padding-top: 0;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 4.5rem;
      padding-bottom: 5.5rem;
    }

    .hero-nameplate {
      font-size: clamp(2.25rem, 10vw, 3.35rem);
    }

    .hero-role {
      font-size: clamp(1.55rem, 7.5vw, 2.25rem);
      max-width: 14ch;
    }

    .hero-lead {
      font-size: 1.02rem;
      max-width: 36ch;
    }

    .proof-signal-band {
      margin-top: 2.5rem;
      padding: 1.4rem 1.25rem;
    }
  }

  @media (max-width: 900px) {
    .split-layout {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .hero-section {
      padding-top: 4rem;
      padding-bottom: 5rem;
    }
  }
  
  @media (max-width: 768px) {
    .essay-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 2rem 0;
    }
  }
</style>
