---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryPageHero from "../../components/RegistryPageHero.astro";
import { aiAgentLifecycleColumn, concepts, pageRegistry, siteConfig, siteSemanticBaseline } from "../../data/site";

const conceptSetJsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "@id": `${siteConfig.siteUrl}/concepts/#defined-term-set`,
  name: pageRegistry.concepts.title,
  description: pageRegistry.concepts.lead,
  url: `${siteConfig.siteUrl}/concepts/`,
  creator: {
    "@id": `${siteConfig.siteUrl}#person`
  },
  hasDefinedTerm: concepts.map((concept) => ({
    "@type": "DefinedTerm",
    name: concept.term,
    description: concept.definition,
    url: `${siteConfig.siteUrl}/concepts/${concept.slug}/`
  }))
};
const primaryConceptStack = [
  {
    term: "AI Agent Lifecycle",
    role: "Field / problem-space",
    description: siteSemanticBaseline.fieldDefinitionStatement,
    href: "/concepts/ai-agent-lifecycle/",
    linkLabel: "Open definition"
  },
  {
    term: "Agentic Delivery",
    role: "Category",
    description: siteSemanticBaseline.agenticDeliveryDefinition,
    href: "/concepts/agentic-delivery/",
    linkLabel: "Open definition"
  },
  {
    term: "MPLP",
    role: "Protocol path",
    description: siteSemanticBaseline.mplpDefinition,
    href: "/projects/mplp/",
    linkLabel: "Open protocol path"
  },
  {
    term: "Multi-Agent Lifecycle Governance",
    role: "Multi-agent form",
    description: siteSemanticBaseline.multiAgentLifecycleGovernanceDefinition,
    href: "/lifecycle/",
    linkLabel: "Open lifecycle field analysis"
  },
  {
    term: "Confirmation Boundary",
    role: "Governance primitive",
    description: siteSemanticBaseline.confirmationBoundaryDefinition,
    href: "/concepts/confirmation-boundary/",
    linkLabel: "Open definition"
  },
  {
    term: "Evidence Chain",
    role: "Governance primitive",
    description: siteSemanticBaseline.evidenceChainDefinition,
    href: "/concepts/lifecycle-evidence/",
    linkLabel: "Open definition"
  },
  {
    term: "Semantic Loss",
    role: "Failure mode",
    description: siteSemanticBaseline.semanticLossDefinition,
    href: "/lifecycle/",
    linkLabel: "Open lifecycle field analysis"
  }
];
const primaryConceptPageSlugs = new Set([
  "ai-agent-lifecycle",
  "agentic-delivery",
  "confirmation-boundary",
  "lifecycle-evidence"
]);
const supportingConcepts = concepts.filter((concept) => !primaryConceptPageSlugs.has(concept.slug));
---

<BaseLayout
  title={pageRegistry.concepts.title}
  description={pageRegistry.concepts.lead}
  canonicalPath="/concepts/"
  jsonLd={[conceptSetJsonLd]}
>
  <RegistryPageHero
    title={pageRegistry.concepts.title}
    objectType={pageRegistry.concepts.objectType}
    objectValue={pageRegistry.concepts.objectValue}
    lead={pageRegistry.concepts.lead}
  >
    <div class="concepts-hero-links">
      <a href="/lifecycle/" class="registry-annotation concepts-hero-link">
        <span class="registry-key">CATEGORY</span>: <span class="registry-value">AI AGENT LIFECYCLE</span>
      </a>
      <a href="/projects/mplp/" class="registry-annotation concepts-hero-link">
        <span class="registry-key">PROTOCOL_PATH</span>: <span class="registry-value">MPLP</span>
      </a>
    </div>
  </RegistryPageHero>

  <div class="zone-b page-body page-body--standard">
    <section class="shell concepts-shell">
      <section class="concept-opening">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">CONCEPT_MAP</span>: <span class="registry-value">REFERENCE_LAYER</span>
        </div>
        <p class="concept-opening__lead">
          Concepts is the reference layer behind the AI Agent Lifecycle mainline. It is not the main human journey.
        </p>
        <p class="concept-opening__copy">
          Use this page to distinguish the primary concept stack from supporting terms. The main public journey still starts at /lifecycle/.
        </p>
      </section>

      <section class="concept-path registry-chassis">
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">READING_PATH</span>: <span class="registry-value">CONCEPT_TO_EVIDENCE</span>
        </div>
        <div class="concept-path__grid">
          <div>
            <h2>Start with the lifecycle category.</h2>
            <p>{aiAgentLifecycleColumn.categoryStatement}</p>
          </div>
          <div class="concept-path__links">
            <a href="/concepts/ai-agent-lifecycle/">AI Agent Lifecycle definition</a>
            <a href="/concepts/agentic-delivery/">Agentic Delivery definition</a>
            <a href="/essays/ai-agent-lifecycle-it-was-not-designed-it-grew/">Origin essay</a>
            <a href="/projects/mplp/">MPLP protocol path</a>
          </div>
        </div>
      </section>

      <section class="concept-tier" aria-labelledby="primary-concept-stack-title">
        <div class="registry-section-heading">
          <div class="registry-annotation" style="margin-bottom: 0.65rem;">
            <span class="registry-key">PRIMARY_CONCEPT_STACK</span>
          </div>
          <h2 id="primary-concept-stack-title">Primary Concept Stack</h2>
          <p class="tier-note">These seven terms are the first-stage public concept stack. Everything else is supporting architecture.</p>
        </div>
        <div class="concept-grid concept-grid--primary">
          {primaryConceptStack.map((entry, index) => (
            <article class="registry-chassis concept-card concept-card--primary">
              <div class="registry-annotation" style="margin-bottom: 0.75rem;">
                <span class="registry-key">STACK_{String(index + 1).padStart(2, "0")}</span>: <span class="registry-value">{entry.role}</span>
              </div>
              <h3><a href={entry.href}>{entry.term}</a></h3>
              <p>{entry.description}</p>
              <a href={entry.href} class="concept-card__link">{entry.linkLabel}</a>
            </article>
          ))}
        </div>
      </section>

      <section class="concept-tier" aria-labelledby="supporting-terms-title">
        <div class="registry-section-heading">
          <div class="registry-annotation" style="margin-bottom: 0.65rem;">
            <span class="registry-key">SUPPORTING_TERMS</span>
          </div>
          <h2 id="supporting-terms-title">Supporting Terms</h2>
          <p class="tier-note">These terms clarify the mainline. They are not first-stage public concepts.</p>
        </div>
        <div class="supporting-term-list">
          {supportingConcepts.map((concept) => (
            <article class="supporting-term-card">
              <h3><a href={`/concepts/${concept.slug}/`}>{concept.term}</a></h3>
              <p>{concept.seoDescription}</p>
              <a href={`/concepts/${concept.slug}/`} class="concept-card__link">Open supporting term</a>
            </article>
          ))}
        </div>
      </section>
    </section>
  </div>
</BaseLayout>

<style>
  .concepts-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.2rem;
    margin-top: 1.4rem;
  }

  .concepts-hero-link {
    text-decoration: none;
  }

  .concepts-hero-link:hover .registry-value {
    color: var(--accent-signal);
  }

  .concepts-shell {
    display: grid;
    gap: var(--space-6);
  }

  .concept-opening {
    max-width: 78ch;
  }

  .concept-opening__lead {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    line-height: 1.48;
    color: var(--current-text);
    font-weight: 650;
    letter-spacing: -0.015em;
  }

  .concept-opening__copy {
    margin: 1rem 0 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--current-muted);
  }

  .concept-path {
    padding: var(--registry-panel-padding);
    border-left: 2px solid var(--accent-proof);
  }

  .concept-path__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 0.46fr);
    gap: 2rem;
    align-items: start;
  }

  .concept-path h2 {
    margin: 0 0 0.8rem;
    font-size: 1.4rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .concept-path p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
  }

  .concept-path__links {
    display: grid;
    gap: 0.75rem;
  }

  .concept-path__links a,
  .concept-card__link {
    color: var(--accent-signal);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .concept-path__links a:hover,
  .concept-card__link:hover,
  .concept-card h3 a:hover,
  .supporting-term-card h3 a:hover {
    color: var(--current-text);
  }

  .concept-tier {
    display: grid;
    gap: 1.4rem;
  }

  .registry-section-heading {
    margin: 0;
  }

  .registry-section-heading h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .tier-note {
    max-width: var(--lead-measure);
    margin: 0.55rem 0 0;
    color: var(--current-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .concept-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .concept-card {
    padding: var(--registry-card-padding);
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .concept-card--primary {
    border-left: 3px solid var(--accent-proof);
  }

  .concept-card h3,
  .supporting-term-card h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .concept-card h3 a,
  .supporting-term-card h3 a {
    color: var(--current-text);
    text-decoration: none;
  }

  .concept-card p,
  .supporting-term-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.62;
    color: var(--current-muted);
  }

  .supporting-term-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--current-line);
  }

  .supporting-term-card {
    display: grid;
    gap: 0.75rem;
    align-content: start;
    padding: var(--registry-supporting-card-padding);
    border-bottom: 1px solid var(--current-line);
    min-width: 0;
  }

  .supporting-term-card h3 {
    font-size: 1.05rem;
  }

  .supporting-term-card p {
    font-size: 0.88rem;
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .concept-path__grid,
    .concept-grid,
    .supporting-term-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .concepts-shell {
      gap: var(--space-4);
    }

    .concept-path,
    .concept-card {
      padding: var(--registry-card-padding);
    }

    .supporting-term-card {
      padding: var(--registry-supporting-card-padding);
    }
  }
</style>
