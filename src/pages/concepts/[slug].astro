---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RegistryPageHero from "../../components/RegistryPageHero.astro";
import { concepts, getConceptBySlug, getProjectBySlug, pageRegistry, siteConfig } from "../../data/site";

export function getStaticPaths() {
  return concepts.map((concept) => ({
    params: { slug: concept.slug }
  }));
}

const { slug } = Astro.params;
const concept = slug ? getConceptBySlug(slug) : undefined;

if (!concept) {
  throw new Error(`Unknown concept: ${slug}`);
}

const essays = await getCollection("essays");
const essaysBySlug = new Map(essays.map((essay) => [essay.slug, essay]));
const relatedEssays = concept.relatedEssays
  .map((essaySlug) => essaysBySlug.get(essaySlug))
  .filter((essay): essay is NonNullable<typeof essay> => Boolean(essay));
const relatedProjects = concept.relatedProjects.reduce<
  Array<NonNullable<ReturnType<typeof getProjectBySlug>>>
>((acc, projectSlug) => {
  const project = getProjectBySlug(projectSlug);
  if (project) acc.push(project);
  return acc;
}, []);
const relatedTerms = concept.relatedTerms
  .map((termSlug) => getConceptBySlug(termSlug))
  .filter((term): term is NonNullable<typeof term> => Boolean(term));
const canonicalPath = `/concepts/${concept.slug}/`;
const conceptUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteConfig.siteUrl
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Concepts",
      item: `${siteConfig.siteUrl}/concepts/`
    },
    {
      "@type": "ListItem",
      position: 3,
      name: concept.term,
      item: conceptUrl
    }
  ]
};
const definedTermJsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "@id": `${conceptUrl}#defined-term`,
  name: concept.term,
  description: concept.definition,
  url: conceptUrl,
  keywords: concept.keywords,
  inDefinedTermSet: {
    "@id": `${siteConfig.siteUrl}/concepts/#defined-term-set`,
    "@type": "DefinedTermSet",
    name: pageRegistry.concepts.title
  }
};
---

<BaseLayout
  title={concept.seoTitle}
  description={concept.seoDescription}
  canonicalPath={canonicalPath}
  jsonLd={[breadcrumbJsonLd, definedTermJsonLd]}
  ogImagePath="/social/jearonwong-og.png"
  ogImageAlt={`${concept.term} - ${siteConfig.author.name}`}
>
  <RegistryPageHero
    title={concept.term}
    objectType="DEFINED_TERM"
    objectValue="AI AGENT LIFECYCLE"
    lead={concept.seoDescription}
  >
    <div class="concept-hero-links">
      <a href="/concepts/" class="registry-annotation concept-hero-link">
        <span class="registry-key">BACK_TO</span>: <span class="registry-value">CONCEPT MAP</span>
      </a>
      <a href="/lifecycle/" class="registry-annotation concept-hero-link">
        <span class="registry-key">CATEGORY</span>: <span class="registry-value">LIFECYCLE</span>
      </a>
    </div>
  </RegistryPageHero>

  <div class="zone-b page-body page-body--standard">
    <article class="shell concept-detail-shell">
      <aside class="registry-chassis concept-sidebar" aria-label={`${concept.term} reference`}>
        <div class="registry-annotation" style="margin-bottom: 1rem;">
          <span class="registry-key">TERM_RECORD</span>
        </div>
        <p class="sidebar-term">{concept.term}</p>
        <div class="sidebar-group">
          <p class="sidebar-label">Primary coverage</p>
          <div class="keyword-list">
            {concept.keywords.map((keyword) => (
              <span>{keyword}</span>
            ))}
          </div>
        </div>
        {relatedTerms.length > 0 && (
          <div class="sidebar-group">
            <p class="sidebar-label">Related terms</p>
            <div class="sidebar-links">
              {relatedTerms.map((term) => (
                <a href={`/concepts/${term.slug}/`}>{term.term}</a>
              ))}
            </div>
          </div>
        )}
      </aside>

      <div class="concept-article">
        <section class="registry-chassis definition-panel">
          <div class="registry-annotation" style="margin-bottom: 1rem;">
            <span class="registry-key">CANONICAL_DEFINITION</span>
          </div>
          <p>{concept.definition}</p>
        </section>

        <section class="concept-section">
          <h2>The problem it names</h2>
          <p>{concept.problem}</p>
        </section>

        <section class="concept-section">
          <h2>Why existing approaches are not enough</h2>
          <p>{concept.whyExistingApproachesAreNotEnough}</p>
        </section>

        <section class="concept-section">
          <h2>How it relates to AI Agent Lifecycle</h2>
          <p>{concept.relationToLifecycle}</p>
        </section>

        <section class="concept-section">
          <h2>Evidence route</h2>
          <p>{concept.evidenceRoute}</p>
        </section>

        <section class="relation-grid" aria-label={`${concept.term} related routes`}>
          {relatedEssays.length > 0 && (
            <article class="registry-chassis relation-panel">
              <div class="registry-annotation" style="margin-bottom: 0.9rem;">
                <span class="registry-key">RELATED_ESSAYS</span>
              </div>
              <h2>Related essays</h2>
              <div class="relation-links">
                {relatedEssays.map((essay) => (
                  <a href={`/essays/${essay.slug}/`}>
                    <strong>{essay.data.title}</strong>
                    <span>{essay.data.description}</span>
                  </a>
                ))}
              </div>
            </article>
          )}

          {relatedProjects.length > 0 && (
            <article class="registry-chassis relation-panel">
              <div class="registry-annotation" style="margin-bottom: 0.9rem;">
                <span class="registry-key">PROOF_PATH</span>
              </div>
              <h2>Related projects / proof path</h2>
              <div class="relation-links">
                {relatedProjects.map((project) => (
                  <a href={`/projects/${project.slug}/`}>
                    <strong>{project.name}</strong>
                    <span>{project.summary}</span>
                  </a>
                ))}
              </div>
            </article>
          )}

          {relatedTerms.length > 0 && (
            <article class="registry-chassis relation-panel relation-panel--wide">
              <div class="registry-annotation" style="margin-bottom: 0.9rem;">
                <span class="registry-key">RELATED_TERMS</span>
              </div>
              <h2>Related terms internal links</h2>
              <div class="term-link-grid">
                {relatedTerms.map((term) => (
                  <a href={`/concepts/${term.slug}/`}>{term.term}</a>
                ))}
              </div>
            </article>
          )}
        </section>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .concept-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1.2rem;
    margin-top: 1.4rem;
  }

  .concept-hero-link {
    text-decoration: none;
  }

  .concept-hero-link:hover .registry-value {
    color: var(--accent-signal);
  }

  .concept-detail-shell {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
    max-width: 1080px;
  }

  .concept-sidebar {
    position: sticky;
    top: 7rem;
    padding: var(--registry-card-padding);
  }

  .sidebar-term {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 760;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .sidebar-group {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--current-line);
  }

  .sidebar-label {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--current-muted);
  }

  .keyword-list,
  .sidebar-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .keyword-list span {
    display: inline-flex;
    padding: 0.3rem 0.45rem;
    border: 1px solid var(--current-line);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.25;
    color: var(--current-muted);
  }

  .sidebar-links a {
    color: var(--accent-signal);
    font-size: 0.86rem;
    line-height: 1.35;
    text-decoration: none;
  }

  .concept-article {
    display: grid;
    gap: 2.5rem;
  }

  .definition-panel {
    padding: var(--registry-panel-padding);
    border-left: 3px solid var(--accent-proof);
  }

  .definition-panel p,
  .concept-section p {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.72;
    color: var(--current-muted);
  }

  .definition-panel p {
    color: var(--current-text);
  }

  .concept-section {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--current-line);
  }

  .concept-section h2,
  .relation-panel h2 {
    margin: 0 0 0.9rem;
    font-size: 1.45rem;
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--current-text);
  }

  .relation-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .relation-panel {
    padding: var(--registry-card-padding);
  }

  .relation-panel--wide {
    grid-column: 1 / -1;
  }

  .relation-links {
    display: grid;
    gap: 1rem;
  }

  .relation-links a {
    display: grid;
    gap: 0.35rem;
    color: var(--current-text);
    text-decoration: none;
  }

  .relation-links strong {
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .relation-links span {
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--current-muted);
  }

  .term-link-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1rem;
  }

  .term-link-grid a {
    color: var(--accent-signal);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .sidebar-links a:hover,
  .relation-links a:hover strong,
  .term-link-grid a:hover {
    color: var(--current-text);
  }

  @media (max-width: 920px) {
    .concept-detail-shell,
    .relation-grid {
      grid-template-columns: 1fr;
    }

    .concept-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .concept-detail-shell {
      gap: 2rem;
    }

    .concept-sidebar,
    .definition-panel,
    .relation-panel {
      padding: var(--registry-card-padding);
    }

    .definition-panel p,
    .concept-section p {
      font-size: 0.98rem;
      line-height: 1.68;
    }
  }
</style>
