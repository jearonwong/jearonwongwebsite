---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { aboutSpecs, pageRegistry } from "../data/site";
---

<BaseLayout title="About">
  <RegistryPageHero
    title={pageRegistry.about.title}
    subtitle={pageRegistry.about.subtitle}
    objectType={pageRegistry.about.objectType}
    objectValue={pageRegistry.about.objectValue}
    lead={pageRegistry.about.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis spec-sheet">
        <div class="spec-grid">
          {aboutSpecs.map((item) => (
            <div class="spec-line">
              <p class="spec-label">{item.label}</p>
              <p class="spec-value">{item.value}</p>
            </div>
          ))}
        </div>

        <div class="spec-narrative">
          <div class="registry-annotation" style="margin-bottom: 1rem;">
            <span class="registry-key">OPERATIONAL_CONTEXT</span>: <span class="registry-value">PUBLIC_HEADQUARTERS</span>
          </div>
          <div class="prose">
            <p>
              I work on the missing systems layer between model capability and real-world delivery:
              the protocols, governance structures, and runtime constraints that make agent work
              legible, reviewable, and reliable.
            </p>
            <p>
              This site is designed as a public headquarters for that thesis. The proof chain is
              explicit, the frameworks are inspectable, and the writing exists to support a category
              definition rather than a generic personal brand story.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .spec-sheet {
    padding: 4rem;
    background: white;
  }
  .spec-grid {
    display: grid;
    gap: 1.4rem;
  }
  .spec-line {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid var(--current-line);
  }
  .spec-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    color: var(--accent-signal);
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .spec-value {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--current-text);
    font-weight: 600;
  }
  .spec-narrative {
    margin-top: 4rem;
    padding-top: 4rem;
    border-top: 1px solid var(--current-line);
  }
  .spec-narrative .prose {
    max-width: 64ch;
    font-size: 1.12rem;
    line-height: 1.7;
    color: var(--current-muted);
  }
  @media (max-width: 768px) {
    .spec-sheet {
      padding: 2rem;
    }
    .spec-line {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
