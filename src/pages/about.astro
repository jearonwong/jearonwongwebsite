---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { aboutSpecs, contentRouteRoles, pageRegistry, siteThesis, socialLinks, siteConfig } from "../data/site";
---

<BaseLayout title="About" description={pageRegistry.about.lead}>
  <RegistryPageHero
    title={pageRegistry.about.title}
    subtitle={pageRegistry.about.subtitle}
    objectType={pageRegistry.about.objectType}
    objectValue={pageRegistry.about.objectValue}
    lead={pageRegistry.about.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis spec-sheet">
        <div class="spec-grid">
          {aboutSpecs.map((item) => (
            <div class="spec-line">
              <p class="spec-label">{item.label}</p>
              <p class="spec-value">{item.value}</p>
            </div>
          ))}
        </div>

        <div class="spec-narrative">
          <div class="registry-annotation" style="margin-bottom: 1rem;">
            <span class="registry-key">OPERATIONAL_CONTEXT</span>: <span class="registry-value">PUBLIC_HEADQUARTERS</span>
          </div>
          <div class="registry-annotation route-question">
            <span class="registry-key">PAGE_QUESTION</span>: <span class="registry-value">{contentRouteRoles.about.question}</span>
          </div>
          <div class="prose">
            <p>
              This is not a generic portfolio. It is a public thesis room for {siteThesis.conceptDefinition}
            </p>
            <p>
              Jearon Wong maintains that thesis through protocol, runtime, product, and evidence
              surfaces: MPLP, Cognitive OS, SoloCrew, and Validation Lab. The writing defines the
              category; the stack proof keeps the claim inspectable.
            </p>
          </div>
        </div>

        <div class="external-verification">
          <div class="registry-annotation" style="margin-bottom: 1.25rem;">
            <span class="registry-key">EXTERNAL_VERIFICATION</span>
          </div>
          <div class="verification-grid">
            {socialLinks.map(link => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="verification-row">
                <span class="verification-key">{link.platform.toUpperCase()}</span>
                <span class="verification-value">{link.label}</span>
              </a>
            ))}
            <a href={`mailto:${siteConfig.author.email}`} class="verification-row">
              <span class="verification-key">EMAIL</span>
              <span class="verification-value">{siteConfig.author.email}</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .spec-sheet {
    padding: 4rem;
    background: white;
  }
  .spec-grid {
    display: grid;
    gap: 1.4rem;
  }
  .spec-line {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid var(--current-line);
  }
  .spec-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    color: var(--accent-signal);
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .spec-value {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--current-text);
    font-weight: 600;
  }
  .spec-narrative {
    margin-top: 4rem;
    padding-top: 4rem;
    border-top: 1px solid var(--current-line);
  }
  .route-question {
    margin-bottom: 1rem;
  }
  .spec-narrative .prose {
    max-width: 64ch;
    font-size: 1.12rem;
    line-height: 1.7;
    color: var(--current-muted);
  }
  @media (max-width: 768px) {
    .spec-sheet {
      padding: 1.6rem;
    }
    .spec-line {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding-bottom: 1rem;
    }
    .spec-value {
      font-size: 1.02rem;
    }
    .spec-narrative {
      margin-top: 2.5rem;
      padding-top: 2.5rem;
    }
    .spec-narrative .prose {
      font-size: 1rem;
      line-height: 1.65;
    }
  }

  .external-verification {
    margin-top: 4rem;
    padding-top: 4rem;
    border-top: 1px solid var(--current-line);
  }
  .verification-grid {
    display: grid;
    gap: 0;
  }
  .verification-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--current-line);
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .verification-row:first-child {
    border-top: 1px solid var(--current-line);
  }
  .verification-row:hover {
    background: rgba(59, 130, 246, 0.03);
  }
  .verification-key {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-signal);
  }
  .verification-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--current-muted);
    letter-spacing: 0.02em;
  }
  @media (max-width: 768px) {
    .verification-row {
      grid-template-columns: 1fr;
      gap: 0.3rem;
      padding: 0.85rem 1rem;
    }
  }
</style>
