---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import { pageRegistry, theoryClusters } from "../data/site";
---

<BaseLayout title="Ideas" canonicalPath="/theories">
  <RegistryPageHero
    title={pageRegistry.ideas.title}
    objectType={pageRegistry.ideas.objectType}
    objectValue={pageRegistry.ideas.objectValue}
    lead={pageRegistry.ideas.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="spec-stack">
        {theoryClusters.map((cluster) => (
          <div class="spec-panel-wrapper">
            <SignatureIdeaCard {...cluster} />
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .spec-stack {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .spec-panel-wrapper {
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 4rem;
  }
  .spec-panel-wrapper:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .spec-stack {
      gap: 2.5rem;
    }
    .spec-panel-wrapper {
      padding-bottom: 2.5rem;
    }
  }
</style>
