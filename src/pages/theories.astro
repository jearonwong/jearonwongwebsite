---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import { aiAgentLifecycleColumn, contentRouteRoles, homepageActions, pageRegistry, theoryClusters } from "../data/site";
---

<BaseLayout title="Ideas" description={pageRegistry.ideas.lead} canonicalPath="/theories/">
  <RegistryPageHero
    title={pageRegistry.ideas.title}
    objectType={pageRegistry.ideas.objectType}
    objectValue={pageRegistry.ideas.objectValue}
    lead={pageRegistry.ideas.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell">
      <div class="registry-chassis registry-panel--reading ideas-guidance">
        <div class="registry-annotation" style="margin-bottom: 0.9rem;">
          <span class="registry-key">START_HERE</span>: <span class="registry-value">IDEAS_TO_ESSAY_TO_PROOF</span>
        </div>
        <p class="ideas-guidance__copy">
          {contentRouteRoles.ideas.question} This is a supporting idea map, not the main theory route.
          The main route is AI Agent Lifecycle; canonical definitions live in Concepts; essays and proof path continue the argument.
        </p>
        <div class="relation-map" aria-label="Concept relationship">
          <span><strong>Agentic Delivery</strong> names the outcome thesis.</span>
          <span><strong>AI Agent Lifecycle</strong> defines the accountable lifecycle of agent work.</span>
          <span><strong>MPLP</strong> is the lifecycle protocol path for the concrete proof path.</span>
        </div>
        <div class="ideas-guidance__links">
          <a href="/concepts/" class="ideas-guidance__link">Open the Concepts map</a>
          <a href={aiAgentLifecycleColumn.href} class="ideas-guidance__link">Open the AI Agent Lifecycle entry</a>
          <a href="/essays/ai-agent-lifecycle-it-was-not-designed-it-grew/" class="ideas-guidance__link">Read the origin essay</a>
          <a href={homepageActions.startHere.href} class="ideas-guidance__link">{homepageActions.startHere.label}</a>
          <a href={homepageActions.proof.href} class="ideas-guidance__link">Then inspect the proof room</a>
        </div>
        <div class="layer-preview" aria-label="AI Agent Lifecycle preview layers">
          {aiAgentLifecycleColumn.previewLayers.map((layer) => (
            <span>{layer}</span>
          ))}
        </div>
      </div>

      <div class="spec-stack">
        {theoryClusters.map((cluster) => (
          <div class="spec-panel-wrapper" id={cluster.slug}>
            <SignatureIdeaCard {...cluster} />
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .ideas-guidance {
    margin-bottom: var(--space-5);
  }

  .ideas-guidance__copy {
    margin: 0;
    max-width: var(--lead-measure);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
  }

  .ideas-guidance__links {
    display: flex;
    flex-wrap: wrap;
    width: fit-content;
    max-width: 100%;
    gap: 0.8rem 1rem;
    margin-top: var(--space-3);
  }

  .relation-map {
    display: grid;
    gap: 0.45rem;
    margin-top: var(--space-3);
    max-width: 62rem;
  }

  .relation-map span {
    color: var(--current-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .relation-map strong {
    color: var(--current-text);
  }

  .ideas-guidance__link {
    color: var(--accent-signal);
    font-size: 0.84rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .ideas-guidance__link:hover {
    color: var(--current-text);
  }

  .layer-preview {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .layer-preview span {
    padding: 0.42rem 0.62rem;
    border: 1px solid var(--current-border);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--current-text);
  }

  .spec-stack {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .spec-panel-wrapper {
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 4rem;
  }
  .spec-panel-wrapper:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .ideas-guidance {
      margin-bottom: var(--space-4);
    }
    .ideas-guidance__copy {
      font-size: 0.95rem;
    }
    .ideas-guidance__link {
      font-size: 0.76rem;
    }
    .spec-stack {
      gap: 2.5rem;
    }
    .spec-panel-wrapper {
      padding-bottom: 2.5rem;
    }
  }
</style>
