---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import SignatureIdeaCard from "../components/SignatureIdeaCard.astro";
import { contentRouteRoles, homepageActions, pageRegistry, siteThesis, theoryClusters } from "../data/site";
---

<BaseLayout title="Ideas" description={pageRegistry.ideas.lead} canonicalPath="/theories">
  <RegistryPageHero
    title={pageRegistry.ideas.title}
    objectType={pageRegistry.ideas.objectType}
    objectValue={pageRegistry.ideas.objectValue}
    lead={pageRegistry.ideas.lead}
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="registry-chassis ideas-guidance">
        <div class="registry-annotation" style="margin-bottom: 0.9rem;">
          <span class="registry-key">START_HERE</span>: <span class="registry-value">IDEAS_TO_ESSAY_TO_PROOF</span>
        </div>
        <p class="ideas-guidance__copy">
          {contentRouteRoles.ideas.question} These concepts make the homepage thesis legible: {siteThesis.conceptDefinition}
          The essays develop the argument; the proof room shows how the concept becomes protocol, runtime, product, and evidence surfaces.
        </p>
        <div class="ideas-guidance__links">
          <a href={homepageActions.startHere.href} class="ideas-guidance__link">{homepageActions.startHere.label}</a>
          <a href={homepageActions.proof.href} class="ideas-guidance__link">Then inspect the proof room</a>
        </div>
      </div>

      <div class="spec-stack">
        {theoryClusters.map((cluster) => (
          <div class="spec-panel-wrapper" id={cluster.slug}>
            <SignatureIdeaCard {...cluster} />
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .ideas-guidance {
    padding: 1.75rem;
    margin-bottom: 2.5rem;
  }

  .ideas-guidance__copy {
    margin: 0;
    max-width: 60ch;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
  }

  .ideas-guidance__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
    margin-top: 1.1rem;
  }

  .ideas-guidance__link {
    color: var(--accent-signal);
    font-size: 0.84rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .ideas-guidance__link:hover {
    color: var(--current-text);
  }

  .spec-stack {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .spec-panel-wrapper {
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 4rem;
  }
  .spec-panel-wrapper:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .ideas-guidance {
      padding: 1.4rem;
      margin-bottom: 2rem;
    }
    .ideas-guidance__copy {
      font-size: 0.95rem;
    }
    .ideas-guidance__link {
      font-size: 0.76rem;
    }
    .spec-stack {
      gap: 2.5rem;
    }
    .spec-panel-wrapper {
      padding-bottom: 2.5rem;
    }
  }
</style>
