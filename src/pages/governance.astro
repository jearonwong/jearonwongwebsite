---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { contentRouteRoles, governanceModules, pageRegistry, siteThesis } from "../data/site";
---

<BaseLayout title="Governance" description={pageRegistry.governance.lead}>
  <RegistryPageHero
    title={pageRegistry.governance.title}
    objectType={pageRegistry.governance.objectType}
    objectValue={pageRegistry.governance.objectValue}
    lead={pageRegistry.governance.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell">
      <div class="registry-chassis appendix-guidance">
        <div class="registry-annotation" style="margin-bottom: 0.9rem;">
          <span class="registry-key">ROUTE_QUESTION</span>: <span class="registry-value">{contentRouteRoles.governance.question}</span>
        </div>
        <p class="appendix-guidance__copy">
          {siteThesis.technicalGap} This is a supporting appendix to the AI Agent Lifecycle mainline. It names the lifecycle conditions that make delegated agent work accountable without turning governance into generic AI safety language.
        </p>
        <a href="/lifecycle/" class="appendix-route-link">Return to Lifecycle mainline</a>
      </div>

      <div class="appendix-stack">
        {governanceModules.map((item) => (
          <article class="registry-chassis appendix-panel" id={item.id}>
            <div class="registry-annotation" style="margin-bottom: 1rem;">
              <span class="registry-key">MODULE</span>: <span class="registry-value">{item.label}</span>
            </div>
            <h2 class="appendix-title">{item.title}</h2>
            <p class="appendix-body">{item.body}</p>
            {(item.relatedConcept || item.relatedEssay) && (
              <div class="appendix-links">
                {item.relatedConcept && <span class="appendix-link-note">Concept: {item.relatedConcept}</span>}
                {item.relatedEssay && <a href={item.relatedEssay} class="appendix-link">Read related essay</a>}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .appendix-guidance {
    padding: var(--registry-panel-padding);
    margin-bottom: var(--space-5);
  }
  .appendix-guidance__copy {
    max-width: var(--content-measure);
    margin: 0;
    color: var(--current-muted);
    font-size: 1rem;
    line-height: 1.65;
  }
  .appendix-route-link {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--accent-signal);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .appendix-route-link:hover {
    color: var(--current-text);
  }
  .appendix-stack {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .appendix-panel {
    padding: var(--registry-panel-padding);
  }
  .appendix-title {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--current-text);
  }
  .appendix-body {
    max-width: 62ch;
    margin: 0;
    color: var(--current-muted);
    line-height: 1.7;
    font-size: 1rem;
  }
  .appendix-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .appendix-link-note {
    color: var(--current-muted);
  }
  .appendix-link {
    color: var(--accent-signal);
    text-decoration: none;
  }
  .appendix-link:hover {
    color: var(--current-text);
  }
  @media (max-width: 768px) {
    .appendix-guidance {
      padding: var(--registry-card-padding);
      margin-bottom: var(--space-4);
    }
    .appendix-stack {
      gap: 1.5rem;
    }
    .appendix-panel {
      padding: var(--registry-card-padding);
    }
    .appendix-title {
      font-size: 1.35rem;
      margin-bottom: 0.8rem;
    }
    .appendix-body {
      font-size: 0.95rem;
      line-height: 1.65;
    }
  }
</style>
