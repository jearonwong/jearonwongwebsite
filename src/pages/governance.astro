---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import { governanceModules, siteConfig } from "../data/site";
---

<BaseLayout title={`Governance | ${siteConfig.title}`}>
  <RegistryPageHero
    title="SYSTEM_GOVERNANCE"
    objectType="OBJECT_TYPE"
    objectValue="SYSTEM_APPENDIX"
    lead="The governance appendix describes the binding conditions for auditable autonomous work."
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="appendix-stack">
        {governanceModules.map((item) => (
          <article class="registry-chassis appendix-panel" id={item.id}>
            <div class="registry-annotation" style="margin-bottom: 1rem;">
              <span class="registry-key">MODULE</span>: <span class="registry-value">{item.label}</span>
            </div>
            <h2 class="appendix-title">{item.title}</h2>
            <p class="appendix-body">{item.body}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .appendix-stack {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .appendix-panel {
    padding: 2.5rem;
  }
  .appendix-title {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--current-text);
  }
  .appendix-body {
    max-width: 62ch;
    margin: 0;
    color: var(--current-muted);
    line-height: 1.7;
    font-size: 1.05rem;
  }
</style>
