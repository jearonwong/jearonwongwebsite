---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { projects } from "../data/site";
import { siteConfig } from "../data/site";
---

<BaseLayout title={`Projects | ${siteConfig.title}`}>
  <div class="zone-a genesis-stage" style="padding-top: 8rem; padding-bottom: 6rem;">
    <SiteHeader />
    <div class="shell">
      <h1 class="text-gradient">Evidence Ledger</h1>
      <p class="lead" style="max-width: 50ch;">Artifacts of a thesis made concrete. Each project is a proof point in the protocol engineering chain.</p>
    </div>
  </div>

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="card-grid">
        {projects.map(project => (
          <ProjectProofCard {...project} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
    gap: 3rem;
  }
  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
