---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { projects, siteConfig } from "../data/site";
---

<BaseLayout title={`Projects | ${siteConfig.title}`}>
  <RegistryPageHero
    title="EVIDENCE_LEDGER"
    objectType="OBJECT_TYPE"
    objectValue="PROOF_ROOM"
    lead="The public proof chain. Each record shows a different layer of the architecture made concrete."
  />

  <div class="zone-b page-body" style="padding: 6rem 0;">
    <section class="shell">
      <div class="evidence-ledger">
        {projects.map((project) => (
          <div class="ledger-item">
            <ProjectProofCard {...project} />
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .evidence-ledger {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .ledger-item {
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 4rem;
  }
  .ledger-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
</style>
