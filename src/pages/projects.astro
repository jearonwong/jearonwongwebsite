---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegistryPageHero from "../components/RegistryPageHero.astro";
import ProjectProofCard from "../components/ProjectProofCard.astro";
import { getProjectBySlug, homepageActions, pageRegistry, siteSemanticBaseline } from "../data/site";

const protocolPathProject = getProjectBySlug("mplp");
const proofPathProjects = ["cognitive-os", "solocrew", "validation-lab"]
  .map((projectSlug) => getProjectBySlug(projectSlug))
  .filter((project): project is NonNullable<ReturnType<typeof getProjectBySlug>> => Boolean(project));
const projectBoundaryNotes = [
  "MPLP is the lifecycle protocol path, not the proof path.",
  "Cognitive OS is a runtime path, not a completed universal runtime.",
  "SoloCrew is a delivery proof path, not finished commercial proof.",
  "Validation Lab is MPLP evidence adjudication, not a credentialing body or general validation service."
];
---

<BaseLayout title="Projects" description={pageRegistry.projects.lead}>
  <RegistryPageHero
    title={pageRegistry.projects.title}
    objectType={pageRegistry.projects.objectType}
    objectValue={pageRegistry.projects.objectValue}
    lead={pageRegistry.projects.lead}
  />

  <div class="zone-b page-body page-body--standard">
    <section class="shell">
      <div class="registry-chassis proof-room-guidance">
        <div class="registry-annotation" style="margin-bottom: 0.9rem;">
          <span class="registry-key">READING_PATH</span>: <span class="registry-value">THESIS_TO_PROOF</span>
        </div>
        <p class="proof-room-guidance__copy">
          This is the project ledger for the AI Agent Lifecycle mainline, not a generic portfolio. {siteSemanticBaseline.referencePathDefinition}
        </p>
        <ul class="boundary-list" aria-label="Project maturity boundaries">
          {projectBoundaryNotes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
        <div class="proof-room-guidance__links">
          <a href="/lifecycle/" class="proof-room-link">Start with AI Agent Lifecycle</a>
          <a href="/essays/" class="proof-room-link">{homepageActions.essays.label}</a>
          <a href="/projects/mplp/" class="proof-room-link">Open the protocol path: MPLP</a>
        </div>
      </div>

      <section class="project-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.75rem;">
            <span class="registry-key">PROTOCOL_PATH</span>
          </div>
          <h2>Protocol Path</h2>
          <p class="section-desc">MPLP is the lifecycle protocol path. It is not the proof path.</p>
        </div>
        <div class="protocol-ledger">
          {protocolPathProject && (
            <ProjectProofCard
              {...protocolPathProject}
              href={`/projects/${protocolPathProject.slug}/`}
              linkLabel="Open the protocol path"
            />
          )}
        </div>
      </section>

      <section class="project-section">
        <div class="section-header">
          <div class="registry-annotation" style="margin-bottom: 0.75rem;">
            <span class="registry-key">PROOF_PATH</span>
          </div>
          <h2>Proof Path</h2>
          <p class="section-desc">Cognitive OS, SoloCrew, and Validation Lab are the concrete proof path through Agentic Delivery.</p>
        </div>
        <div class="proof-ledger">
          {proofPathProjects.map((project) => (
            <div class="ledger-item" id={project.slug}>
              <ProjectProofCard
                {...project}
                href={`/projects/${project.slug}/`}
              />
            </div>
          ))}
        </div>
      </section>
    </section>
  </div>
</BaseLayout>

<style>
  .proof-room-guidance {
    padding: var(--registry-panel-padding);
    margin-bottom: var(--space-5);
  }

  .proof-room-guidance__copy {
    margin: 0;
    max-width: var(--lead-measure);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--current-muted);
  }

  .boundary-list {
    display: grid;
    gap: 0.45rem;
    margin: 1.25rem 0 0;
    padding-left: 1.35rem;
    max-width: var(--content-measure);
    color: var(--current-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .proof-room-guidance__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
    margin-top: var(--space-3);
  }

  .proof-room-link {
    color: var(--accent-signal);
    font-size: 0.84rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .proof-room-link:hover {
    color: var(--current-text);
  }

  .project-section {
    display: grid;
    gap: 1.35rem;
    margin-top: var(--space-6);
  }

  .section-header h2 {
    margin: 0 0 0.6rem;
    color: var(--current-text);
    font-size: clamp(1.6rem, 3vw, 2.15rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .section-desc {
    max-width: 64ch;
    margin: 0;
    color: var(--current-muted);
    font-size: 0.98rem;
    line-height: 1.62;
  }

  .protocol-ledger {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .proof-ledger {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .ledger-item {
    border-bottom: 1px solid var(--current-line);
    padding-bottom: 4rem;
  }
  .ledger-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .proof-room-guidance {
      padding: var(--registry-card-padding);
      margin-bottom: var(--space-4);
    }
    .proof-room-guidance__copy {
      font-size: 0.95rem;
    }
    .boundary-list {
      font-size: 0.88rem;
    }
    .proof-room-link {
      font-size: 0.76rem;
    }

    .project-section {
      margin-top: 2.25rem;
    }

    .proof-ledger {
      gap: 2.5rem;
    }

    .ledger-item {
      padding-bottom: 2.5rem;
    }
  }
</style>
